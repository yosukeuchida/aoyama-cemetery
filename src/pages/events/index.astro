---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const events = await getCollection('events');
events.sort((a, b) => a.data.date.localeCompare(b.data.date));

const people = await getCollection('people');
const peopleNameById = new Map(people.map((p) => [p.id, p.data.name]));

const CATEGORY_COLOR: Record<string, string> = {
  政変: '#8a5a2a',
  戦争: '#6b3a2a',
  事件: '#a23b56',
  条約: '#4a5a8a',
  内閣: '#3a5a8a',
  災害: '#6b5a2a',
  社会: '#3a5a3a',
};

function eraLabel(year: number): string {
  if (year <= 1867) return '江戸';
  if (year <= 1911) return '明治';
  if (year <= 1925) return '大正';
  if (year <= 1988) return '昭和';
  if (year <= 2018) return '平成';
  return '令和';
}

const title = '事件一覧 - 青山霊園 偉人録';
const description = '青山霊園に眠る偉人と関わる歴史的事件・戦争・条約・政変などを時系列で一覧。桜田門外の変から東京オリンピック開会まで、本サイト登録の偉人とつながる節目の出来事 25 件。';

const siteOrigin = new URL('/', Astro.site).toString();

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップ', item: siteOrigin },
    { '@type': 'ListItem', position: 2, name: '事件', item: new URL('/events/', Astro.site).toString() },
  ],
};
---

<BaseLayout title={title} description={description} jsonLd={breadcrumbJsonLd}>
  <h1>事件一覧</h1>
  <p>青山霊園に眠る偉人たちが関わった歴史的な出来事を、時系列順に並べた索引です。各事件をクリックすると詳細と関連する偉人の一覧が見られます。</p>

  <ul class="events-list">
    {events.map((event) => {
      const [yStr, mStr, dStr] = event.data.date.split('-');
      const year = parseInt(yStr, 10);
      const month = parseInt(mStr, 10);
      const day = parseInt(dStr, 10);
      const themeColor = CATEGORY_COLOR[event.data.category] ?? '#777';
      const personNames = event.data.personSlugs.map((s) => peopleNameById.get(s) ?? s);
      return (
        <li class="event-card">
          <a href={`/events/${event.id}/`}>
            <div class="event-card-header">
              <span class="event-category" style={`background:${themeColor};`}>
                {event.data.category}
              </span>
              <span class="event-card-date">
                {eraLabel(year)} {year} 年 {month}/{day}
              </span>
            </div>
            <h2 class="event-card-title">{event.data.title}</h2>
            <p class="event-card-summary">{event.data.summary}</p>
            <p class="event-card-related">関連: {personNames.join('・')}</p>
          </a>
        </li>
      );
    })}
  </ul>
</BaseLayout>

<style>
  .events-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin-top: 1.5rem;
  }
  .event-card {
    border: 1px solid #d6d3c7;
    border-radius: 6px;
    background: #faf8f3;
    transition: box-shadow 120ms ease;
  }
  .event-card:hover {
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
  }
  .event-card a {
    display: block;
    padding: 0.8rem 1rem;
    text-decoration: none;
    color: inherit;
  }
  .event-card-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.4rem;
  }
  .event-category {
    display: inline-block;
    padding: 0.1rem 0.55rem;
    border-radius: 3px;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .event-card-date {
    color: #8a7a55;
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
  }
  .event-card-title {
    font-size: 1.05rem;
    margin: 0 0 0.4rem;
    color: #5a4a2a;
  }
  .event-card-summary {
    margin: 0 0 0.4rem;
    font-size: 0.88rem;
    line-height: 1.6;
    color: #444;
  }
  .event-card-related {
    margin: 0;
    font-size: 0.78rem;
    color: #888;
  }
</style>
