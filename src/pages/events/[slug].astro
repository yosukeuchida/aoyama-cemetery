---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const events = await getCollection('events');
  const people = await getCollection('people');
  const peopleMap = new Map(people.map((p) => [p.id, p]));
  return events.map((event) => ({
    params: { slug: event.id },
    props: { event, peopleMap },
  }));
}

interface Props {
  event: CollectionEntry<'events'>;
  peopleMap: Map<string, CollectionEntry<'people'>>;
}

const { event, peopleMap } = Astro.props;
const { Content } = await render(event);

const relatedPeople = event.data.personSlugs
  .map((slug) => peopleMap.get(slug))
  .filter((p): p is CollectionEntry<'people'> => p !== undefined);

const [yearStr, monthStr, dayStr] = event.data.date.split('-');
const yearNum = parseInt(yearStr, 10);
const monthNum = parseInt(monthStr, 10);
const dayNum = parseInt(dayStr, 10);

function eraLabel(year: number): string {
  if (year <= 1867) return '江戸';
  if (year <= 1911) return '明治';
  if (year <= 1925) return '大正';
  if (year <= 1988) return '昭和';
  if (year <= 2018) return '平成';
  return '令和';
}

const CATEGORY_COLOR: Record<string, string> = {
  政変: '#8a5a2a',
  戦争: '#6b3a2a',
  事件: '#a23b56',
  条約: '#4a5a8a',
  内閣: '#3a5a8a',
  災害: '#6b5a2a',
  社会: '#3a5a3a',
};

const title = `${event.data.title}(${yearNum}年) - 青山霊園 偉人録`;
const description = event.data.summary;

const siteOrigin = new URL('/', Astro.site).toString();

const eventJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: event.data.title,
  description: event.data.summary,
  startDate: event.data.date,
  url: new URL(`/events/${event.id}/`, Astro.site).toString(),
  ...(event.data.url ? { sameAs: [event.data.url] } : {}),
  about: relatedPeople.map((p) => ({
    '@type': 'Person',
    name: p.data.name,
    url: new URL(`/people/${p.id}/`, Astro.site).toString(),
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップ', item: siteOrigin },
    { '@type': 'ListItem', position: 2, name: '事件', item: new URL('/events/', Astro.site).toString() },
    {
      '@type': 'ListItem',
      position: 3,
      name: event.data.title,
      item: new URL(`/events/${event.id}/`, Astro.site).toString(),
    },
  ],
};

const themeColor = CATEGORY_COLOR[event.data.category] ?? '#777';
---

<BaseLayout title={title} description={description} jsonLd={[eventJsonLd, breadcrumbJsonLd]}>
  <nav class="breadcrumb" aria-label="パンくず">
    <a href="/">トップ</a>
    <span aria-hidden="true">/</span>
    <a href="/events/">事件</a>
    <span aria-hidden="true">/</span>
    <span aria-current="page">{event.data.title}</span>
  </nav>

  <article class="event-detail">
    <section class="hero">
      <span class="label-small">E V E N T</span>
      <h1>{event.data.title}</h1>
      <hr class="hairline" />
      <p class="lead">{event.data.summary}</p>
    </section>

    {event.data.heroImage && (
      <figure class="event-hero-image">
        <Image
          src={event.data.heroImage}
          alt={event.data.heroImageCaption ?? `${event.data.title} を象徴する画像`}
          widths={[480, 720, 1080]}
          sizes="(max-width: 720px) 100vw, 720px"
          quality={82}
        />
        {(event.data.heroImageCaption || event.data.heroImageCredit) && (
          <figcaption>
            {event.data.heroImageCaption && <span class="caption">{event.data.heroImageCaption}</span>}
            {event.data.heroImageCredit && <span class="credit">{event.data.heroImageCredit}</span>}
          </figcaption>
        )}
      </figure>
    )}

    <dl class="meta-grid">
      <div class="meta-cell">
        <dt>日付</dt>
        <dd>
          <time datetime={event.data.date}>
            {eraLabel(yearNum)} {yearNum} 年 {monthNum} 月 {dayNum} 日
          </time>
        </dd>
      </div>
      <div class="meta-cell">
        <dt>カテゴリ</dt>
        <dd>
          <span class="event-category" style={`--cat-color:${themeColor};`}>
            {event.data.category}
          </span>
        </dd>
      </div>
    </dl>

    <article class="event-body">
      <Content />
    </article>

    <section class="event-related">
      <h2>関連する偉人</h2>
      <ul class="event-related-list">
        {relatedPeople.map((p) => (
          <li>
            <a href={`/people/${p.id}/`} class="related-person-card">
              <div class="related-person-thumb">
                {p.data.portrait ? (
                  <Image
                    src={p.data.portrait}
                    alt={`${p.data.name}の肖像`}
                    width={120}
                    quality={80}
                  />
                ) : (
                  <div class="related-person-thumb-placeholder">
                    <span>肖像</span>
                    <span>未公開</span>
                  </div>
                )}
              </div>
              <div class="related-person-info">
                <span class="related-person-name">{p.data.name}</span>
                <span class="related-person-meta">
                  {p.data.birthDate.slice(0, 4)}-{p.data.deathDate.slice(0, 4)}
                  <span class="era-badge">{p.data.era.join('・')}</span>
                  <span class="category-badge">{p.data.category}</span>
                </span>
                <span class="related-person-desc">{p.data.shortDescription}</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>

    {event.data.url && (
      <section class="event-references">
        <h2>参考資料</h2>
        <ul>
          <li><a href={event.data.url} target="_blank" rel="noopener">Wikipedia: {event.data.title}</a></li>
        </ul>
      </section>
    )}

    <p class="back-foot"><a href="/events/">← 事件一覧に戻る</a></p>
  </article>
</BaseLayout>

<style>
  .breadcrumb {
    font-size: 0.72rem;
    color: var(--color-text-faint);
    letter-spacing: 0.1em;
    margin-bottom: 1.6rem;
  }
  .breadcrumb a {
    color: var(--color-text-faint);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--color-accent-gold); }
  .breadcrumb span[aria-hidden] { margin: 0 0.4em; color: var(--color-border); }

  .hero {
    text-align: center;
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }
  .hero .label-small { display: block; margin-bottom: 0.6rem; }
  .hero h1 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 2rem;
    letter-spacing: 0.1em;
    color: var(--color-ink);
    margin: 0 0 1rem;
    padding: 0;
    border: 0;
  }
  .hero .hairline { margin: 0 auto 1.3rem; }
  .hero .lead {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 2.0;
    letter-spacing: 0.06em;
    color: var(--color-text-sub);
    max-width: var(--max-width-narrow);
    margin: 0 auto;
  }

  .meta-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.45rem;
    margin: 0 auto 2.5rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--color-border);
    max-width: var(--max-width-narrow);
    font-size: 0.88rem;
  }
  .meta-cell {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0.5rem;
  }
  .meta-cell dt {
    color: var(--color-text-faint);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    padding-top: 0.2rem;
    margin: 0;
  }
  .meta-cell dd {
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
    font-variant-numeric: tabular-nums;
  }

  .event-category {
    display: inline-block;
    padding: 0.15rem 0.7rem;
    border-radius: 2px;
    background: var(--cat-color, var(--color-accent));
    color: var(--color-bg);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    font-variant-numeric: normal;
  }

  .event-body {
    margin-bottom: 2rem;
    line-height: 1.95;
    color: var(--color-text);
  }
  .event-body :global(p) {
    margin: 0.6rem 0 0.8rem;
  }
  .event-body :global(ul) {
    padding-left: 1.4rem;
  }
  .event-body :global(li) {
    margin: 0.2rem 0;
  }

  .event-hero-image {
    margin: 0 auto 2rem;
    max-width: 720px;
    padding: 6px;
    background: #fff;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
    line-height: 0;
  }
  .event-hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }
  .event-hero-image figcaption {
    line-height: 1.5;
    margin-top: 0.5rem;
    padding: 0 0.3rem 0.3rem;
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }
  .event-hero-image .caption { display: block; }
  .event-hero-image .credit {
    display: block;
    font-size: 0.7rem;
    color: var(--color-text-faint);
    margin-top: 0.2rem;
  }

  .event-related-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 0.9rem;
  }
  .related-person-card {
    display: flex;
    gap: 0.8rem;
    padding: 1rem 1.1rem;
    background: var(--color-card);
    border-left: 2px solid var(--color-accent);
    text-decoration: none;
    color: inherit;
    transition: border-left-width 0.15s ease, background 0.15s ease;
  }
  .related-person-card:hover {
    border-left-width: 3px;
    background: #fbf7eb;
  }
  .related-person-thumb {
    flex: 0 0 auto;
    width: 60px;
    aspect-ratio: 3 / 4;
    padding: 3px;
    background: #fff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
    overflow: hidden;
    line-height: 0;
  }
  .related-person-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .related-person-thumb-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-bg-alt);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 0.6rem;
    color: var(--color-text-faint);
    letter-spacing: 0.1em;
    line-height: 1.5;
  }
  .related-person-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .related-person-name {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-ink);
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  .related-person-meta {
    font-size: 0.78rem;
    color: var(--color-text-sub);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    font-variant-numeric: tabular-nums;
  }
  .era-badge,
  .category-badge {
    background: var(--color-bg-alt);
    color: var(--color-text-sub);
    padding: 0.05rem 0.4rem;
    border-radius: 2px;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
  }
  .related-person-desc {
    font-size: 0.85rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  .event-references ul {
    padding-left: 1.2rem;
  }
  .event-references a {
    color: var(--color-accent);
  }
  .event-references a:hover { color: var(--color-accent-gold); }

  .back-foot {
    margin-top: 2.5rem;
    font-size: 0.85rem;
  }
  .back-foot a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }
  .back-foot a:hover {
    color: var(--color-accent-gold);
    border-bottom-color: var(--color-accent-gold);
  }
</style>
