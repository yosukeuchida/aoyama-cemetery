---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GravePhotoGallery from '../../components/GravePhotoGallery.astro';

export async function getStaticPaths() {
  const people = await getCollection('people');
  return people.map((person) => ({
    params: { slug: person.id },
    props: { person },
  }));
}

interface Props {
  person: CollectionEntry<'people'>;
}

const { person } = Astro.props;
const { Content } = await render(person);

const title = `${person.data.name} - 青山霊園 偉人録`;
const description = person.data.shortDescription;
---

<BaseLayout title={title} description={description} ogImage={person.data.ogImage}>
  <article class="person-detail">
    <h1>{person.data.name}</h1>
    <p class="kana">{person.data.nameKana}({person.data.nameRomaji})</p>

    <table class="meta-table">
      <tbody>
        <tr><th>生没年</th><td>{person.data.birthDate} 〜 {person.data.deathDate}</td></tr>
        <tr><th>時代</th><td>{person.data.era.join('・')}</td></tr>
        <tr><th>分野</th><td>{person.data.category}</td></tr>
        {person.data.graveSection && <tr><th>墓所区画</th><td>{person.data.graveSection}</td></tr>}
        {person.data.tags && person.data.tags.length > 0 && (
          <tr><th>タグ</th><td>{person.data.tags.join(' / ')}</td></tr>
        )}
      </tbody>
    </table>

    <Content />

    <GravePhotoGallery slug={person.id} />

    {!person.data.hideMap && (() => {
      const mapQuery = person.data.coords
        ? `${person.data.coords.lat},${person.data.coords.lng}`
        : person.data.mapQuery ?? `${person.data.name}の墓 青山霊園`;
      const linkQuery = person.data.coords
        ? `${person.data.coords.lat},${person.data.coords.lng}(${person.data.name}の墓)`
        : person.data.mapQuery ?? `${person.data.name}の墓 青山霊園`;
      return (
        <section class="grave-map">
          <h2>墓所の位置</h2>
          <iframe
            title={`${person.data.name}の墓所地図`}
            src={`https://maps.google.com/maps?q=${encodeURIComponent(mapQuery)}&z=18&output=embed`}
            width="100%"
            height="450"
            style="border:0; border-radius:8px;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
          <p class="map-link">
            <a
              href={`https://www.google.com/maps?q=${encodeURIComponent(linkQuery)}`}
              target="_blank"
              rel="noopener"
            >
              Google マップで開く →
            </a>
          </p>
        </section>
      );
    })()}

    {person.data.references && person.data.references.length > 0 && (
      <section class="references">
        <h2>参考資料</h2>
        <ul>
          {person.data.references.map((ref) => (
            <li><a href={ref.url} target="_blank" rel="noopener">{ref.title}</a></li>
          ))}
        </ul>
      </section>
    )}

    <p><a href="/">← 偉人一覧に戻る</a></p>
  </article>
</BaseLayout>
