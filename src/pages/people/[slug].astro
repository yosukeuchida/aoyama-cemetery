---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GravePhotoGallery from '../../components/GravePhotoGallery.astro';
import NearbyGraves from '../../components/NearbyGraves.astro';
import PersonPortrait from '../../components/PersonPortrait.astro';
import RelatedPeople from '../../components/RelatedPeople.astro';
import RelatedWorks from '../../components/RelatedWorks.astro';
import { getNearbyPeople } from '../../utils/nearby-graves';
import { getRelatedPeopleFor } from '../../utils/related-people';
import { getWorksForPerson } from '../../utils/related-works';
import { getRoutesForPerson } from '../../utils/routes-for-person';
import { getEventsForPerson } from '../../utils/events-for-person';
import { getGitDates } from '../../utils/git-dates';

export async function getStaticPaths() {
  const people = await getCollection('people');
  return people.map((person) => ({
    params: { slug: person.id },
    props: { person },
  }));
}

interface Props {
  person: CollectionEntry<'people'>;
}

const { person } = Astro.props;
const { Content } = await render(person);
const { block, nearby } = await getNearbyPeople(person);
const works = await getWorksForPerson(person.id);
const routes = await getRoutesForPerson(person.id);
const events = await getEventsForPerson(person.id);
const relatedPeople = await getRelatedPeopleFor(person);

const title = `${person.data.name} - 青山霊園 偉人録`;
const description = person.data.shortDescription;

const portraitSrc = person.data.portrait?.src;
const ogImage = person.data.ogImage ?? portraitSrc;
const absolutePortraitURL = portraitSrc
  ? new URL(portraitSrc, Astro.site).toString()
  : undefined;
const pageURL = new URL(Astro.url.pathname, Astro.site).toString();
const siteOrigin = new URL('/', Astro.site).toString();

const sameAs = (person.data.references ?? [])
  .map((r) => r.url)
  .filter((u) => u.includes('wikipedia.org'));

const personJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: person.data.name,
  alternateName: person.data.nameKana,
  birthDate: person.data.birthDate,
  deathDate: person.data.deathDate,
  description: person.data.shortDescription,
  url: pageURL,
  nationality: person.data.nationality,
  ...(absolutePortraitURL ? { image: absolutePortraitURL } : {}),
  ...(sameAs.length > 0 ? { sameAs } : {}),
  ...(person.data.birthPlace
    ? { birthPlace: { '@type': 'Place', name: person.data.birthPlace } }
    : {}),
  ...(person.data.deathPlace
    ? { deathPlace: { '@type': 'Place', name: person.data.deathPlace } }
    : {}),
  ...(person.data.jobTitle ? { jobTitle: person.data.jobTitle } : {}),
  ...(person.data.knowsAbout && person.data.knowsAbout.length > 0
    ? { knowsAbout: person.data.knowsAbout }
    : {}),
  ...(person.data.alumniOf && person.data.alumniOf.length > 0
    ? {
        alumniOf: person.data.alumniOf.map((name) => ({
          '@type': 'EducationalOrganization',
          name,
        })),
      }
    : {}),
  ...(person.data.honorificSuffix ? { honorificSuffix: person.data.honorificSuffix } : {}),
  ...(person.data.award && person.data.award.length > 0 ? { award: person.data.award } : {}),
  ...(person.data.memberOf && person.data.memberOf.length > 0
    ? {
        memberOf: person.data.memberOf.map((name) => ({ '@type': 'Organization', name })),
      }
    : {}),
  burialPlace: {
    '@type': 'Place',
    name: '青山霊園',
    address: {
      '@type': 'PostalAddress',
      addressCountry: 'JP',
      addressLocality: '東京都港区',
      streetAddress: '南青山2丁目',
    },
    ...(person.data.graveSection ? { description: `区画: ${person.data.graveSection}` } : {}),
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: '青山霊園 偉人録',
      item: siteOrigin,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: person.data.name,
    },
  ],
};

const faqAnswers: { q: string; a: string }[] = [
  {
    q: `${person.data.name}とはどのような人物ですか?`,
    a: person.data.shortDescription,
  },
  {
    q: `${person.data.name}の生没年はいつですか?`,
    a: `${person.data.birthDate} 生まれ、${person.data.deathDate} 没。時代区分は${person.data.era.join('・')}。`,
  },
];
if (person.data.graveSection) {
  faqAnswers.push({
    q: `${person.data.name}はどこに眠っていますか?`,
    a: `東京・青山霊園 ${person.data.graveSection} に埋葬されている。`,
  });
}

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqAnswers.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: a,
    },
  })),
};

const { datePublished, dateModified } = getGitDates(`src/content/people/${person.id}.md`);

const publisher = {
  '@type': 'Organization',
  name: '青山霊園 偉人録',
  url: siteOrigin,
};

const articleJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished,
  dateModified,
  author: publisher,
  publisher,
  mainEntityOfPage: pageURL,
  ...(absolutePortraitURL ? { image: absolutePortraitURL } : {}),
  about: {
    '@type': 'Person',
    name: person.data.name,
    url: pageURL,
  },
  inLanguage: 'ja',
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  ogType="profile"
  jsonLd={[articleJsonLd, personJsonLd, breadcrumbJsonLd, faqJsonLd]}
>
  <article class="person-detail">
    <nav class="breadcrumb" aria-label="パンくずリスト">
      <a href="/">トップ</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">{person.data.name}</span>
    </nav>

    <div class="person-head">
      <div class="person-head-left">
        <PersonPortrait
          portrait={person.data.portrait}
          name={person.data.name}
          birthYear={person.data.birthDate.slice(0, 4)}
          deathYear={person.data.deathDate.slice(0, 4)}
          caption={person.data.portraitCaption}
          credit={person.data.portraitCredit}
        />
      </div>
      <div class="person-head-right">
        <span class="label-small">P E R S O N</span>
        <h1 class="person-name">{person.data.name}</h1>
        <p class="kana">{person.data.nameKana}</p>
        <p class="romaji">{person.data.nameRomaji}</p>
        <p class="summary">{person.data.shortDescription}</p>
        <dl class="meta-grid">
          <div class="meta-cell"><dt>生没年</dt><dd><time datetime={person.data.birthDate}>{person.data.birthDate.slice(0, 4)}</time> — <time datetime={person.data.deathDate}>{person.data.deathDate.slice(0, 4)}</time></dd></div>
          {person.data.birthPlace && (
            <div class="meta-cell"><dt>出身地</dt><dd>{person.data.birthPlace}</dd></div>
          )}
          {person.data.deathPlace && (
            <div class="meta-cell"><dt>死没地</dt><dd>{person.data.deathPlace}</dd></div>
          )}
          <div class="meta-cell"><dt>時代</dt><dd>{person.data.era.join('・')}</dd></div>
          <div class="meta-cell"><dt>役職</dt><dd>{person.data.jobTitle ?? person.data.category}</dd></div>
          {person.data.honorificSuffix && (
            <div class="meta-cell"><dt>爵位</dt><dd>{person.data.honorificSuffix}</dd></div>
          )}
          {person.data.alumniOf && person.data.alumniOf.length > 0 && (
            <div class="meta-cell meta-cell-wide"><dt>出身校</dt><dd>{person.data.alumniOf.join(' / ')}</dd></div>
          )}
          {person.data.memberOf && person.data.memberOf.length > 0 && (
            <div class="meta-cell meta-cell-wide"><dt>所属</dt><dd>{person.data.memberOf.join(' / ')}</dd></div>
          )}
          {person.data.award && person.data.award.length > 0 && (
            <div class="meta-cell meta-cell-wide"><dt>受勲</dt><dd>{person.data.award.join(' / ')}</dd></div>
          )}
          {person.data.graveSection && (
            <div class="meta-cell meta-cell-wide"><dt>区画</dt><dd>{person.data.graveSection}</dd></div>
          )}
          {person.data.tags && person.data.tags.length > 0 && (
            <div class="meta-cell meta-cell-wide"><dt>タグ</dt><dd>{person.data.tags.join(' / ')}</dd></div>
          )}
        </dl>
      </div>
    </div>

    <Content />

    <GravePhotoGallery slug={person.id} />

    {!person.data.hideMap && (() => {
      const mapQuery = person.data.coords
        ? `${person.data.coords.lat},${person.data.coords.lng}`
        : person.data.mapQuery ?? `${person.data.name}の墓 青山霊園`;
      const linkQuery = person.data.coords
        ? `${person.data.coords.lat},${person.data.coords.lng}(${person.data.name}の墓)`
        : person.data.mapQuery ?? `${person.data.name}の墓 青山霊園`;
      return (
        <section class="grave-map">
          <h2>墓所の位置</h2>
          <iframe
            title={`${person.data.name}の墓所地図`}
            src={`https://maps.google.com/maps?q=${encodeURIComponent(mapQuery)}&z=18&output=embed`}
            width="100%"
            height="450"
            style="border:0; border-radius:8px;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
          <p class="map-link">
            <a
              href={`https://www.google.com/maps?q=${encodeURIComponent(linkQuery)}`}
              target="_blank"
              rel="noopener"
            >
              Google マップで開く →
            </a>
          </p>
        </section>
      );
    })()}

    {block && nearby.length > 0 && <NearbyGraves block={block} nearby={nearby} />}

    {works.length > 0 && <RelatedWorks works={works} />}

    <RelatedPeople items={relatedPeople} />

    {events.length > 0 && (
      <section class="person-events">
        <h2>関与した事件</h2>
        <ul class="person-events-list">
          {events.map((ev) => {
            const [yStr, mStr, dStr] = ev.data.date.split('-');
            return (
              <li>
                <a href={`/events/${ev.id}/`}>
                  <span class="person-event-date">{yStr}/{parseInt(mStr, 10)}/{parseInt(dStr, 10)}</span>
                  <span class="person-event-title">{ev.data.title}</span>
                  <span class="person-event-summary">{ev.data.summary}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    )}

    {routes.length > 0 && (
      <section class="person-routes">
        <h2>この偉人を含む散歩コース</h2>
        <ul class="person-routes-list">
          {routes.map((route) => (
            <li>
              <a href={`/routes/${route.id}/`}>
                <span class="person-route-title">{route.data.title}</span>
                <span class="person-route-meta">
                  {route.data.theme} / 所要 {route.data.estimatedMinutes} 分 / {route.data.stops.length} 名
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {person.data.references && person.data.references.length > 0 && (
      <section class="references">
        <h2>参考資料</h2>
        <ul>
          {person.data.references.map((ref) => (
            <li><a href={ref.url} target="_blank" rel="noopener">{ref.title}</a></li>
          ))}
        </ul>
      </section>
    )}

    <p><a href="/">← 偉人一覧に戻る</a></p>
  </article>
</BaseLayout>

<style>
  .person-head {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2.5rem;
    align-items: start;
    margin-bottom: 2rem;
  }
  .person-head-right .label-small {
    display: inline-block;
    margin-bottom: 0.6rem;
  }
  .person-head-right .person-name {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 2.2rem;
    letter-spacing: 0.1em;
    color: var(--color-ink);
    margin: 0 0 0.3rem;
    line-height: 1.4;
    padding: 0;
    border: 0;
  }
  .person-head-right .kana {
    color: var(--color-text-muted);
    font-size: 0.88rem;
    letter-spacing: 0.08em;
    margin: 0;
  }
  .person-head-right .romaji {
    color: var(--color-text-faint);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    margin: 0.25rem 0 0;
  }
  .person-head-right .summary {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.95;
    color: var(--color-text-sub);
    margin: 1.3rem 0 1.4rem;
    padding-left: 1rem;
    border-left: 2px solid var(--color-accent);
  }
  .meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.45rem 1.5rem;
    margin: 0;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.85rem;
  }
  .meta-cell {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 0.5rem;
  }
  .meta-cell-wide {
    grid-column: 1 / -1;
  }
  .meta-cell dt {
    color: var(--color-text-faint);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    padding-top: 0.2rem;
    margin: 0;
  }
  .meta-cell dd {
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 720px) {
    .person-head {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      justify-items: center;
    }
    .person-head-right { width: 100%; }
    .person-head-right .person-name { font-size: 1.7rem; letter-spacing: 0.06em; }
    .meta-grid { grid-template-columns: 1fr; }
    .meta-cell, .meta-cell-wide { grid-template-columns: 80px 1fr; }
  }

  .person-events {
    margin-top: 2.5rem;
  }
  .person-events h2 {
    border-bottom: 1px solid #ddd;
    padding-bottom: 0.3rem;
    margin-bottom: 1rem;
  }
  .person-events-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .person-events-list a {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.6rem 0.9rem;
    border: 1px solid #d6d3c7;
    border-radius: 6px;
    background: #faf8f3;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 120ms ease;
  }
  .person-events-list a:hover {
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
  }
  .person-event-date {
    font-size: 0.78rem;
    color: #8a7a55;
    font-variant-numeric: tabular-nums;
  }
  .person-event-title {
    font-size: 0.95rem;
    color: #5a4a2a;
    font-weight: 500;
  }
  .person-event-summary {
    font-size: 0.85rem;
    color: #444;
    line-height: 1.5;
  }

  .person-routes {
    margin-top: 2.5rem;
  }
  .person-routes h2 {
    border-bottom: 1px solid #ddd;
    padding-bottom: 0.3rem;
    margin-bottom: 1rem;
  }
  .person-routes-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.6rem;
  }
  .person-routes-list a {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid #d6d3c7;
    border-radius: 6px;
    background: #faf8f3;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 120ms ease;
  }
  .person-routes-list a:hover {
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
  }
  .person-route-title {
    font-size: 0.95rem;
    color: #5a4a2a;
    font-weight: 500;
  }
  .person-route-meta {
    font-size: 0.78rem;
    color: #8a7a55;
  }
</style>
