---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

const CATEGORY_ORDER = ['政治家', '軍人', '実業家', '学者', '文化人', 'その他'] as const;
type Category = (typeof CATEGORY_ORDER)[number];

const people = await getCollection('people');

const groups: Record<Category, typeof people> = {
  政治家: [],
  軍人: [],
  実業家: [],
  学者: [],
  文化人: [],
  その他: [],
};

for (const p of people) {
  groups[p.data.category as Category].push(p);
}

for (const cat of CATEGORY_ORDER) {
  groups[cat].sort((a, b) => a.data.nameKana.localeCompare(b.data.nameKana, 'ja'));
}

const totalCount = people.length;

const peopleDatesData = people.map((p) => ({
  id: p.id,
  name: p.data.name,
  birthDate: p.data.birthDate,
  deathDate: p.data.deathDate,
  category: p.data.category,
  shortDescription: p.data.shortDescription,
}));

const eventsCollection = await getCollection('events');
const peopleNameById = new Map(people.map((p) => [p.id, p.data.name]));
const eventsData = eventsCollection.map((e) => ({
  id: e.id,
  title: e.data.title,
  date: e.data.date,
  summary: e.data.summary,
  category: e.data.category,
  personSlugs: e.data.personSlugs,
  personNames: e.data.personSlugs.map((s) => peopleNameById.get(s) ?? s),
  url: e.data.url ?? null,
}));

const ERA_ORDER = ['江戸', '明治', '大正', '昭和'] as const;
const presentEras = ERA_ORDER.filter((era) => people.some((p) => p.data.era.includes(era)));
const presentCategories = CATEGORY_ORDER.filter((cat) => groups[cat].length > 0);

const SECTION_RE = /^(\d+種[ァ-ヺ]\d+号)/;
const IROHA = 'イロハニホヘトチリヌルヲワカヨタレソツネナラムウヰノオクヤマケフコエテアサキユメミシヱヒモセスン';

function extractSectionKey(s: string | undefined): string {
  if (!s) return '';
  const m = s.match(SECTION_RE);
  return m ? m[1] : '';
}

const sectionKeyByPersonId = new Map<string, string>();
const sectionCounts = new Map<string, number>();
for (const p of people) {
  const key = extractSectionKey(p.data.graveSection);
  sectionKeyByPersonId.set(p.id, key);
  if (key) sectionCounts.set(key, (sectionCounts.get(key) ?? 0) + 1);
}

type ParsedSection = { key: string; prefix: number; rowIdx: number; no: number; count: number };
const sectionOptions: ParsedSection[] = Array.from(sectionCounts.entries())
  .map(([key, count]) => {
    const m = key.match(/^(\d+)種([ァ-ヺ])(\d+)号$/);
    return {
      key,
      prefix: m ? Number(m[1]) : 0,
      rowIdx: m ? IROHA.indexOf(m[2]) : -1,
      no: m ? Number(m[3]) : 0,
      count,
    };
  })
  .sort((a, b) => a.prefix - b.prefix || a.rowIdx - b.rowIdx || a.no - b.no);

const PREFECTURE_ORDER = [
  '北海道', '青森県', '岩手県', '宮城県', '秋田県', '山形県', '福島県',
  '茨城県', '栃木県', '群馬県', '埼玉県', '千葉県', '東京都', '神奈川県',
  '新潟県', '富山県', '石川県', '福井県', '山梨県', '長野県', '岐阜県',
  '静岡県', '愛知県', '三重県', '滋賀県', '京都府', '大阪府', '兵庫県',
  '奈良県', '和歌山県', '鳥取県', '島根県', '岡山県', '広島県', '山口県',
  '徳島県', '香川県', '愛媛県', '高知県', '福岡県', '佐賀県', '長崎県',
  '熊本県', '大分県', '宮崎県', '鹿児島県', '沖縄県',
];
const PREF_PATTERN = /(東京都|東京府|北海道|京都府|大阪府|[^県、)(]+?県)/;

function extractPrefecture(s: string | undefined): string {
  if (!s) return '';
  const modernMatch = s.match(/現・(東京都|東京府|北海道|京都府|大阪府|[^県、)(]+?県)/);
  if (modernMatch) {
    return modernMatch[1] === '東京府' ? '東京都' : modernMatch[1];
  }
  const anyMatch = s.match(PREF_PATTERN);
  if (anyMatch) {
    return anyMatch[1] === '東京府' ? '東京都' : anyMatch[1];
  }
  return '';
}

const prefectureByPersonId = new Map<string, string>();
const prefectureCounts = new Map<string, number>();
for (const p of people) {
  const pref = extractPrefecture(p.data.birthPlace);
  prefectureByPersonId.set(p.id, pref);
  if (pref) prefectureCounts.set(pref, (prefectureCounts.get(pref) ?? 0) + 1);
}

const birthPlaceOptions: { key: string; count: number }[] = PREFECTURE_ORDER
  .filter((p) => prefectureCounts.has(p))
  .map((p) => ({ key: p, count: prefectureCounts.get(p)! }));

const title = '青山霊園 偉人録';
const description = '東京・青山霊園に眠る偉人たちを紹介するサイト。明治維新を担った政治家、文学者、軍人、文化人の足跡をたどります。';

const siteOrigin = new URL('/', Astro.site).toString();

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: title,
  description,
  url: siteOrigin,
  inLanguage: 'ja',
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: title,
      item: siteOrigin,
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[websiteJsonLd, breadcrumbJsonLd]}
>
  <noscript>
    <style>
      .era-filter,
      .category-filter,
      .birthplace-filter,
      .section-filter,
      .people-count {
        display: none;
      }
    </style>
  </noscript>

  <section class="hero">
    <h1>青山霊園に眠る<br />偉人たち</h1>
    <hr class="hairline" />
    <p class="lead">
      港区南青山。<br />
      近代日本を駆け抜けた政治家、軍人、文豪、学者たちが<br />
      静かに眠る都心の杜を、人物とともに歩く。
    </p>
    <p class="count"><strong>{totalCount}</strong>人の物語</p>
  </section>

  <div class="today-grid">
    <section class="today-widget today-widget-people" aria-live="polite">
      <h2 class="today-widget-title">
        <span class="today-icon" aria-hidden="true">🕯️</span>
        生誕と命日 <span class="today-date" id="today-date-label-people">…</span>
        <span class="today-range">本日から 7 日</span>
      </h2>
      <ul class="today-list" id="today-people-list">
        <li class="today-empty">読み込み中…</li>
      </ul>
    </section>

    <section class="today-widget today-widget-history" aria-live="polite">
      <h2 class="today-widget-title">
        <span class="today-icon" aria-hidden="true">📜</span>
        今日の歴史 <span class="today-date" id="today-date-label-history">…</span>
        <span class="today-range">本日から 7 日</span>
      </h2>
      <ul class="today-list" id="today-history-list">
        <li class="today-empty">読み込み中…</li>
      </ul>
    </section>
  </div>

  <script type="application/json" id="people-dates-data" set:html={JSON.stringify(peopleDatesData)}></script>
  <script type="application/json" id="events-data" set:html={JSON.stringify(eventsData)}></script>

  <div class="era-filter" role="toolbar" aria-label="時代で絞り込み">
    <span class="filter-label">時代:</span>
    <button type="button" class="era-chip is-active" data-era="all" aria-pressed="true">
      すべて
    </button>
    {
      presentEras.map((era) => (
        <button type="button" class="era-chip" data-era={era} aria-pressed="false">
          {era}
        </button>
      ))
    }
  </div>

  <div class="category-filter" role="toolbar" aria-label="職業で絞り込み">
    <span class="filter-label">職業:</span>
    <button type="button" class="category-chip is-active" data-category="all" aria-pressed="true">
      すべて
    </button>
    {
      presentCategories.map((cat) => (
        <button type="button" class="category-chip" data-category={cat} aria-pressed="false">
          {cat}
        </button>
      ))
    }
  </div>

  <div class="birthplace-filter">
    <label class="filter-label" for="birthplace-select">出身地:</label>
    <select id="birthplace-select" aria-label="出身地で絞り込み">
      <option value="all">すべて</option>
      {birthPlaceOptions.map((b) => (
        <option value={b.key}>{b.key} ({b.count}名)</option>
      ))}
    </select>
  </div>

  <div class="section-filter">
    <label class="filter-label" for="section-select">区画:</label>
    <select id="section-select" aria-label="区画で絞り込み">
      <option value="all">すべて</option>
      {sectionOptions.map((s) => (
        <option value={s.key}>{s.key} ({s.count}名)</option>
      ))}
    </select>
  </div>

  <p class="people-count" aria-live="polite">全 {totalCount} 名</p>

  {
    CATEGORY_ORDER.map((cat) => {
      const list = groups[cat];
      if (list.length === 0) return null;
      return (
        <section class="category-section" data-category={cat}>
          <header class="section-title">
            <span class="label-small">P E O P L E</span>
            <h2>{cat} <span class="section-count">({list.length})</span></h2>
          </header>
          <div class="people-grid">
            {list.map((person) => (
              <article class="person-card" data-eras={person.data.era.join(',')} data-category={person.data.category} data-section={sectionKeyByPersonId.get(person.id) ?? ''} data-birthplace={prefectureByPersonId.get(person.id) ?? ''}>
                <a class="person-card-thumb" href={`/people/${person.id}/`} aria-hidden="true" tabindex="-1">
                  {person.data.portrait ? (
                    <Image
                      src={person.data.portrait}
                      alt=""
                      widths={[180, 240]}
                      sizes="90px"
                      quality={80}
                    />
                  ) : (
                    <span class="person-card-thumb-placeholder">
                      <span>肖像</span>
                      <span>未公開</span>
                    </span>
                  )}
                </a>
                <div class="person-card-body">
                  <h3 class="person-name">
                    <a href={`/people/${person.id}/`}>{person.data.name}</a>
                  </h3>
                  <p class="person-kana">{person.data.nameKana}</p>
                  <p class="person-meta">
                    {person.data.birthDate.slice(0, 4)} - {person.data.deathDate.slice(0, 4)}
                    <span class="era-badge">{person.data.era.join('・')}</span>
                  </p>
                  <p class="person-desc">{person.data.shortDescription}</p>
                </div>
              </article>
            ))}
          </div>
        </section>
      );
    })
  }
</BaseLayout>

<style>
  /* === Hero === */
  .hero {
    text-align: center;
    padding: 4rem 0 3.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }
  .hero h1 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 2.4rem;
    line-height: 1.55;
    letter-spacing: 0.12em;
    color: var(--color-ink);
    margin: 0 0 1.5rem;
    padding: 0;
    border: 0;
  }
  .hero .hairline {
    margin: 0 auto 1.5rem;
  }
  .hero .lead {
    font-family: var(--font-serif);
    font-size: 0.98rem;
    line-height: 2.1;
    letter-spacing: 0.06em;
    color: var(--color-text-sub);
    max-width: var(--max-width-narrow);
    margin: 0 auto;
  }
  .hero .count {
    margin: 2.2rem 0 0;
    font-size: 0.72rem;
    letter-spacing: 0.3em;
    color: var(--color-text-faint);
  }
  .hero .count strong {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.5rem;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    margin: 0 0.3em;
  }
  @media (max-width: 720px) {
    .hero { padding: 2.5rem 0 2.2rem; margin-bottom: 1.8rem; }
    .hero h1 { font-size: 1.8rem; letter-spacing: 0.06em; }
  }

  /* === Today widgets === */
  .today-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 0.8rem;
    margin: 0 0 2rem;
  }
  .today-widget {
    padding: 1rem 1.1rem;
    background: var(--color-card);
    border-left: 2px solid var(--color-accent);
  }
  .today-widget-history {
    border-left-color: var(--color-accent-gold);
  }
  .today-widget-title {
    font-family: var(--font-serif);
    font-weight: 500;
    margin: 0 0 0.5rem;
    font-size: 1rem;
    color: var(--color-ink);
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0;
    border: 0;
  }
  .today-icon { font-size: 1.05rem; }
  .today-date { color: var(--color-accent-gold); font-weight: 500; }
  .today-range {
    font-size: 0.7rem;
    color: var(--color-text-faint);
    letter-spacing: 0.1em;
    margin-left: 0.4rem;
  }
  .today-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .today-list li {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--color-text);
  }
  .today-list a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }
  .today-list a:hover { color: var(--color-accent-gold); border-bottom-color: var(--color-accent-gold); }

  .event-action {
    display: inline-block;
    padding: 0 0.3rem;
    font-size: 0.75rem;
    font-weight: 600;
    margin: 0 0.25rem 0 0.1rem;
  }
  .event-action.birth { color: #5a7a18; }
  .event-action.death { color: #6b3a1a; }
  .event-related {
    color: var(--color-text-muted);
    font-size: 0.78rem;
    display: block;
    margin-top: 0.15rem;
  }
  .event-related a { color: var(--color-accent); }
  .event-date {
    color: var(--color-text-faint);
    font-variant-numeric: tabular-nums;
    margin-right: 0.3rem;
    font-size: 0.82rem;
  }
  .event-year {
    color: var(--color-text-faint);
    font-size: 0.78rem;
    margin-left: 0.3rem;
  }
  .today-empty {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-style: italic;
  }
  .event-today-marker {
    color: #a23b56;
    font-weight: 600;
    margin-left: 0.3rem;
  }

  /* === Filters === */
  .era-filter,
  .category-filter {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    margin: 1rem 0 0.5rem;
  }
  .category-filter { margin-top: 0.3rem; }
  .section-filter,
  .birthplace-filter {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0.3rem 0 0.5rem;
  }
  .filter-label {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    margin-right: 0.2rem;
  }
  .era-chip,
  .category-chip {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    padding: 0.3rem 0.85rem;
    font-size: 0.82rem;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: 0.05em;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .era-chip:hover,
  .category-chip:hover {
    background: var(--color-bg-alt);
    border-color: var(--color-accent-gold);
  }
  .era-chip.is-active,
  .category-chip.is-active {
    background: var(--color-ink);
    color: var(--color-bg);
    border-color: var(--color-ink);
  }
  .section-filter select,
  .birthplace-filter select {
    background: #fff;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    padding: 0.3rem 0.6rem;
    font-size: 0.85rem;
    font-family: inherit;
    cursor: pointer;
  }

  .people-count {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    margin: 0.7rem 0 1.8rem;
  }

  /* === Section title === */
  .category-section {
    margin-bottom: 3rem;
  }
  .section-title {
    text-align: left;
    margin: 0 0 1rem;
  }
  .section-title .label-small {
    display: block;
    margin-bottom: 0.3rem;
  }
  .section-title h2 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.3rem;
    color: var(--color-ink);
    letter-spacing: 0.1em;
    margin: 0;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .section-count {
    color: var(--color-text-faint);
    font-size: 0.85rem;
    font-weight: normal;
    letter-spacing: 0.05em;
    margin-left: 0.3em;
  }

  /* === People grid === */
  .people-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.7rem;
  }
  @media (max-width: 720px) {
    .people-grid { grid-template-columns: 1fr; }
    .person-card { padding: 0.8rem 0.9rem; gap: 0.7rem; }
    .person-card-thumb { flex: 0 0 72px; width: 72px; height: 72px; }
  }

  .person-card {
    background: var(--color-card);
    border-left: 2px solid var(--color-accent);
    padding: 1.1rem 1.2rem;
    transition: border-left-width 0.15s ease, background 0.15s ease;
    display: flex;
    gap: 0.9rem;
    align-items: flex-start;
  }
  .person-card:hover {
    border-left-width: 3px;
    background: #fbf7eb;
  }
  .person-card-thumb {
    flex: 0 0 90px;
    width: 90px;
    height: 90px;
    overflow: hidden;
    border-radius: 2px;
    background: var(--color-bg-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }
  .person-card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .person-card-thumb-placeholder {
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(45deg, var(--color-bg-alt) 0 6px, transparent 6px 12px);
    border: 1px dashed var(--color-border-faint);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--color-text-faint);
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    line-height: 1.3;
  }
  .person-card-body {
    flex: 1 1 auto;
    min-width: 0;
  }
  .person-name {
    margin: 0 0 0.2rem;
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.15rem;
    color: var(--color-ink);
    letter-spacing: 0.05em;
    padding: 0;
    border: 0;
  }
  .person-name a {
    color: inherit;
    text-decoration: none;
  }
  .person-name a:hover { color: var(--color-accent-gold); }
  .person-kana {
    margin: 0 0 0.4rem;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  .person-meta {
    margin: 0 0 0.5rem;
    color: var(--color-text-faint);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .era-badge {
    background: var(--color-ink);
    color: var(--color-bg);
    padding: 0.15rem 0.55rem;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
  }
  .person-desc {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.75;
    color: var(--color-text-sub);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .person-card { transition: none; }
  }
</style>

<script>
  // 今日の暦 / 今日の歴史 ウィジェット
  type PersonDate = {
    id: string;
    name: string;
    birthDate: string;
    deathDate: string;
    category: string;
    shortDescription: string;
  };

  type EventDataItem = {
    id: string;
    title: string;
    date: string;
    summary: string;
    category: string;
    personSlugs: string[];
    personNames: string[];
    url: string | null;
  };

  const peopleDatesScript = document.getElementById('people-dates-data');
  const eventsScript = document.getElementById('events-data');

  if (peopleDatesScript) {
    const peopleDates: PersonDate[] = JSON.parse(peopleDatesScript.textContent || '[]');
    const eventsRaw: EventDataItem[] = eventsScript
      ? JSON.parse(eventsScript.textContent || '[]')
      : [];
    const now = new Date();
    const todayMonth = now.getMonth() + 1;
    const todayDay = now.getDate();
    const dateText = `(${todayMonth}/${todayDay})`;

    for (const id of ['today-date-label-people', 'today-date-label-history']) {
      const el = document.getElementById(id);
      if (el) el.textContent = dateText;
    }

    const DAYS_FORWARD = 7;
    const yearNow = now.getFullYear();

    function dateToDayOfYear(month: number, day: number): number {
      const cumulativeDaysNonLeap = [0, 31, 59, 90, 120, 151, 181, 212, 243, 273, 304, 334];
      return cumulativeDaysNonLeap[month - 1] + day;
    }

    const todayDayOfYear = dateToDayOfYear(todayMonth, todayDay);

    type PersonEvent = {
      kind: 'birth' | 'death';
      person: PersonDate;
      month: number;
      day: number;
      year: number;
      diff: number;
    };
    type HistEvent = {
      event: EventDataItem;
      month: number;
      day: number;
      year: number;
      diff: number;
    };

    function diffForwardOnly(month: number, day: number): number | null {
      const eventDayOfYear = dateToDayOfYear(month, day);
      let diff = eventDayOfYear - todayDayOfYear;
      if (diff < 0) diff += 365;
      return diff <= DAYS_FORWARD ? diff : null;
    }

    const personEvents: PersonEvent[] = [];
    for (const p of peopleDates) {
      for (const [type, dateStr] of [['birth', p.birthDate], ['death', p.deathDate]] as const) {
        if (!dateStr) continue;
        const [yStr, mStr, dStr] = dateStr.split('-');
        const month = parseInt(mStr, 10);
        const day = parseInt(dStr, 10);
        const year = parseInt(yStr, 10);
        if (!month || !day) continue;
        const diff = diffForwardOnly(month, day);
        if (diff !== null) {
          personEvents.push({ kind: type, person: p, month, day, year, diff });
        }
      }
    }

    const histEvents: HistEvent[] = [];
    for (const ev of eventsRaw) {
      const [yStr, mStr, dStr] = ev.date.split('-');
      const month = parseInt(mStr, 10);
      const day = parseInt(dStr, 10);
      const year = parseInt(yStr, 10);
      if (!month || !day) continue;
      const diff = diffForwardOnly(month, day);
      if (diff !== null) {
        histEvents.push({ event: ev, month, day, year, diff });
      }
    }

    function sortByDiff<T extends { diff: number; year: number }>(arr: T[]) {
      arr.sort((a, b) => {
        if (a.diff !== b.diff) return a.diff - b.diff;
        return a.year - b.year;
      });
    }
    sortByDiff(personEvents);
    sortByDiff(histEvents);

    function renderPerson(e: PersonEvent): string {
      const yearsAgo = yearNow - e.year;
      const fullDate = `${e.year}/${e.month}/${e.day}`;
      const agoLabel = e.kind === 'death' ? `没後 ${yearsAgo} 年` : `生誕 ${yearsAgo} 年`;
      return `
        <li>
          <span class="event-date">${fullDate}</span>
          <a href="/people/${e.person.id}/">${e.person.name}</a>
          <span class="event-year">/ ${agoLabel}</span>
        </li>
      `;
    }

    function renderHist(e: HistEvent): string {
      const fullDate = `${e.year}/${e.month}/${e.day}`;
      const yearsAgo = yearNow - e.year;
      const personLinks = e.event.personSlugs
        .map((s, i) => `<a href="/people/${s}/">${e.event.personNames[i]}</a>`)
        .join('・');
      const relatedHtml = personLinks
        ? `<span class="event-related">関連: ${personLinks}</span>`
        : '';
      return `
        <li>
          <span class="event-date">${fullDate}</span>
          <strong><a href="/events/${e.event.id}/">${e.event.title}</a></strong>
          <span class="event-year">/ ${yearsAgo} 年前</span>
          ${relatedHtml}
        </li>
      `;
    }

    function fillList<T>(
      listId: string,
      items: T[],
      renderFn: (item: T) => string,
      emptyMessage: string
    ) {
      const list = document.getElementById(listId);
      if (!list) return;
      if (items.length === 0) {
        list.innerHTML = `<li class="today-empty">${emptyMessage}</li>`;
      } else {
        list.innerHTML = items.map(renderFn).join('');
      }
    }

    fillList(
      'today-people-list',
      personEvents,
      renderPerson,
      '今日から 7 日以内に該当する偉人がいません。'
    );

    fillList(
      'today-history-list',
      histEvents,
      renderHist,
      '今日から 7 日以内に該当する出来事がありません。'
    );
  }

  const eraChips = document.querySelectorAll<HTMLButtonElement>('.era-chip');
  const catChips = document.querySelectorAll<HTMLButtonElement>('.category-chip');
  const sectionSelect = document.querySelector<HTMLSelectElement>('#section-select');
  const birthPlaceSelect = document.querySelector<HTMLSelectElement>('#birthplace-select');
  const articles = document.querySelectorAll<HTMLElement>('.person-card');
  const categorySections = document.querySelectorAll<HTMLElement>('.category-section');
  const countEl = document.querySelector<HTMLElement>('.people-count');
  const totalCount = articles.length;

  const validSectionKeys = new Set<string>();
  if (sectionSelect) {
    sectionSelect.querySelectorAll('option').forEach((o) => {
      if (o.value && o.value !== 'all') validSectionKeys.add(o.value);
    });
  }
  const validBirthPlaceKeys = new Set<string>();
  if (birthPlaceSelect) {
    birthPlaceSelect.querySelectorAll('option').forEach((o) => {
      if (o.value && o.value !== 'all') validBirthPlaceKeys.add(o.value);
    });
  }

  let currentEra = 'all';
  let currentCategory = 'all';
  let currentSection = 'all';
  let currentBirthPlace = 'all';

  function applyFilter() {
    eraChips.forEach((chip) => {
      const active = chip.dataset.era === currentEra;
      chip.classList.toggle('is-active', active);
      chip.setAttribute('aria-pressed', active ? 'true' : 'false');
    });
    catChips.forEach((chip) => {
      const active = chip.dataset.category === currentCategory;
      chip.classList.toggle('is-active', active);
      chip.setAttribute('aria-pressed', active ? 'true' : 'false');
    });
    if (sectionSelect && sectionSelect.value !== currentSection) {
      sectionSelect.value = currentSection;
    }
    if (birthPlaceSelect && birthPlaceSelect.value !== currentBirthPlace) {
      birthPlaceSelect.value = currentBirthPlace;
    }

    let visible = 0;
    articles.forEach((article) => {
      const matchEra =
        currentEra === 'all' ||
        (article.dataset.eras ?? '').split(',').includes(currentEra);
      const matchCat = currentCategory === 'all' || article.dataset.category === currentCategory;
      const matchSection =
        currentSection === 'all' || article.dataset.section === currentSection;
      const matchBirthPlace =
        currentBirthPlace === 'all' || article.dataset.birthplace === currentBirthPlace;
      const match = matchEra && matchCat && matchSection && matchBirthPlace;
      article.hidden = !match;
      if (match) visible += 1;
    });

    categorySections.forEach((section) => {
      const cards = section.querySelectorAll<HTMLElement>('.person-card');
      const visibleInSection = Array.from(cards).filter((c) => !c.hidden).length;
      section.hidden = visibleInSection === 0;
      const countSpan = section.querySelector<HTMLElement>('.section-count');
      if (countSpan) countSpan.textContent = `(${visibleInSection})`;
    });

    if (countEl) {
      const filtered =
        currentEra !== 'all' ||
        currentCategory !== 'all' ||
        currentSection !== 'all' ||
        currentBirthPlace !== 'all';
      countEl.textContent = filtered
        ? `${visible} 名を表示中 (全 ${totalCount} 名)`
        : `全 ${totalCount} 名`;
    }
  }

  function parseHash(): { era: string; category: string; section: string; birth: string } {
    const result = { era: 'all', category: 'all', section: 'all', birth: 'all' };
    const raw = location.hash.startsWith('#') ? location.hash.slice(1) : '';
    if (!raw) return result;
    let params: URLSearchParams;
    try {
      params = new URLSearchParams(raw);
    } catch {
      return result;
    }
    const section = params.get('section');
    if (section && validSectionKeys.has(section)) {
      result.section = section;
      return result;
    }
    const era = params.get('era');
    if (era && Array.from(eraChips).some((c) => c.dataset.era === era)) {
      result.era = era;
    }
    const category = params.get('cat');
    if (category && Array.from(catChips).some((c) => c.dataset.category === category)) {
      result.category = category;
    }
    const birth = params.get('birth');
    if (birth && validBirthPlaceKeys.has(birth)) {
      result.birth = birth;
    }
    return result;
  }

  function syncHash() {
    const params = new URLSearchParams();
    if (currentSection !== 'all') {
      params.set('section', currentSection);
    } else {
      if (currentEra !== 'all') params.set('era', currentEra);
      if (currentCategory !== 'all') params.set('cat', currentCategory);
      if (currentBirthPlace !== 'all') params.set('birth', currentBirthPlace);
    }
    const query = params.toString();
    const url = query
      ? `${location.pathname}${location.search}#${query}`
      : location.pathname + location.search;
    history.replaceState(null, '', url);
  }

  eraChips.forEach((chip) => {
    chip.addEventListener('click', () => {
      currentEra = chip.dataset.era || 'all';
      currentSection = 'all';
      applyFilter();
      syncHash();
    });
  });

  catChips.forEach((chip) => {
    chip.addEventListener('click', () => {
      currentCategory = chip.dataset.category || 'all';
      currentSection = 'all';
      applyFilter();
      syncHash();
    });
  });

  if (birthPlaceSelect) {
    birthPlaceSelect.addEventListener('change', () => {
      currentBirthPlace = birthPlaceSelect.value || 'all';
      currentSection = 'all';
      applyFilter();
      syncHash();
    });
  }

  if (sectionSelect) {
    sectionSelect.addEventListener('change', () => {
      currentSection = sectionSelect.value || 'all';
      if (currentSection !== 'all') {
        currentEra = 'all';
        currentCategory = 'all';
        currentBirthPlace = 'all';
      }
      applyFilter();
      syncHash();
    });
  }

  window.addEventListener('hashchange', () => {
    const parsed = parseHash();
    currentEra = parsed.era;
    currentCategory = parsed.category;
    currentSection = parsed.section;
    currentBirthPlace = parsed.birth;
    applyFilter();
  });

  const initial = parseHash();
  currentEra = initial.era;
  currentCategory = initial.category;
  currentSection = initial.section;
  currentBirthPlace = initial.birth;
  applyFilter();
</script>
