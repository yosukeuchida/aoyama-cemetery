---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RouteMap from '../../components/RouteMap.astro';

export async function getStaticPaths() {
  const routes = await getCollection('routes');
  const people = await getCollection('people');
  const peopleMap = new Map(people.map((p) => [p.id, p]));
  return routes.map((route) => ({
    params: { slug: route.id },
    props: { route, peopleMap },
  }));
}

interface Props {
  route: CollectionEntry<'routes'>;
  peopleMap: Map<string, CollectionEntry<'people'>>;
}

const { route, peopleMap } = Astro.props;
const { Content } = await render(route);

type Stop = (typeof route.data.stops)[number];

const stops = route.data.stops.map((stop: Stop) => ({
  stop,
  person: peopleMap.get(stop.slug),
}));

const missing = stops.filter((s) => !s.person).map((s) => s.stop.slug);
if (missing.length > 0) {
  throw new Error(
    `Route ${route.id} references unknown person slug(s): ${missing.join(', ')}`
  );
}

// 散歩経路マップ用: 全 stops が coords を持っている場合のみ表示
const mapStops = stops
  .map(({ stop, person }) => {
    const coords = person!.data.coords;
    if (!coords) return null;
    return {
      slug: person!.id,
      name: person!.data.name,
      lat: coords.lat,
      lng: coords.lng,
    };
  })
  .filter((s): s is { slug: string; name: string; lat: number; lng: number } => s !== null);

const showRouteMap = mapStops.length === stops.length && stops.length >= 2;

const walkOrder = route.data.walkOrder;

const THEME_COLOR: Record<string, string> = {
  維新: '#8a5a2a',
  戊辰戦争: '#6b3a2a',
  坂の上の雲: '#2a4a6b',
  昭和: '#3a5a8a',
  太平洋戦争: '#4a3a2a',
  文人: '#3a5a3a',
  お雇い外国人: '#7b4b94',
  女性とハチ公: '#c75d3b',
  軍人: '#5a4a2a',
  実業家: '#8a6a2a',
  官僚: '#4a5a6b',
  その他: '#777',
};

const title = `${route.data.title} - 散歩コース | 青山霊園 偉人録`;
const description = route.data.description;

const siteOrigin = new URL('/', Astro.site).toString();

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: route.data.title,
  description: route.data.description,
  numberOfItems: stops.length,
  itemListElement: stops.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: s.person!.data.name,
    url: new URL(`/people/${s.person!.id}/`, Astro.site).toString(),
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップ', item: siteOrigin },
    { '@type': 'ListItem', position: 2, name: '散歩コース', item: new URL('/routes/', Astro.site).toString() },
    {
      '@type': 'ListItem',
      position: 3,
      name: route.data.title,
      item: new URL(`/routes/${route.id}/`, Astro.site).toString(),
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[itemListJsonLd, breadcrumbJsonLd]}
>
  <nav class="breadcrumb" aria-label="パンくずリスト">
    <a href="/">トップ</a>
    <span aria-hidden="true">›</span>
    <a href="/routes/">散歩コース</a>
    <span aria-hidden="true">›</span>
    <span aria-current="page">{route.data.title}</span>
  </nav>

  <section class="hero">
    <span class="label-small">R O U T E</span>
    <h1>{route.data.title}</h1>
    {route.data.subtitle && <p class="hero-subtitle">{route.data.subtitle}</p>}
    <hr class="hairline" />
    <p class="lead">{route.data.description}</p>
    <p class="hero-meta">
      <span
        class="hero-theme"
        style={`background:${THEME_COLOR[route.data.theme] ?? '#777'};`}
      >{route.data.theme}</span>
      <span>所要 {route.data.estimatedMinutes} 分</span>
      <span>{route.data.stops.length} 名</span>
    </p>
  </section>

  {showRouteMap && <RouteMap stops={mapStops} walkOrder={walkOrder} />}

  <article class="route-content">
    <Content />
  </article>

  <section class="stops">
    <h2>巡る人物({stops.length} 名)</h2>
    <ol class="stops-list">
      {stops.map(({ stop, person }, i) => (
        <li class="stop-item">
          <div class="stop-num">{i + 1}</div>
          <div class="stop-thumb">
            {person!.data.portrait ? (
              <Image
                src={person!.data.portrait}
                alt={`${person!.data.name}の肖像`}
                width={120}
                quality={80}
              />
            ) : (
              <div class="stop-thumb-placeholder">
                <span>肖像</span>
                <span>未公開</span>
              </div>
            )}
          </div>
          <div class="stop-body">
            <h3 class="stop-name">
              <a href={`/people/${person!.id}/`}>{person!.data.name}</a>
              <span class="stop-kana">{person!.data.nameKana}</span>
            </h3>
            <p class="stop-life">
              {person!.data.birthDate.slice(0, 4)} - {person!.data.deathDate.slice(0, 4)}
              <span class="era-badge">{person!.data.era.join('・')}</span>
              <span class="category-badge">{person!.data.category}</span>
              {person!.data.graveSection && (
                <span class="section-badge">{person!.data.graveSection}</span>
              )}
            </p>
            {stop.note && <p class="stop-note">{stop.note}</p>}
          </div>
        </li>
      ))}
    </ol>
  </section>

</BaseLayout>

<style>
  .breadcrumb {
    font-size: 0.72rem;
    color: var(--color-text-faint);
    letter-spacing: 0.1em;
    margin-bottom: 1.6rem;
  }
  .breadcrumb a {
    color: var(--color-text-faint);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--color-accent-gold); }
  .breadcrumb span[aria-hidden] { margin: 0 0.4em; color: var(--color-border); }

  .hero {
    text-align: center;
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }
  .hero .label-small { display: block; margin-bottom: 0.6rem; }
  .hero h1 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 2rem;
    letter-spacing: 0.12em;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
    padding: 0;
    border: 0;
  }
  .hero-subtitle {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0 0 1rem;
  }
  .hero .hairline { margin: 0 auto 1.3rem; }
  .hero .lead {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    line-height: 2.0;
    letter-spacing: 0.06em;
    color: var(--color-text-sub);
    max-width: var(--max-width-narrow);
    margin: 0 auto 1.4rem;
  }
  .hero-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.2rem;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: var(--color-text-faint);
    margin: 0;
    flex-wrap: wrap;
  }
  .hero-theme {
    display: inline-block;
    padding: 0.18rem 0.7rem;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
  }

  /* stops list — uses the same card pattern as person-card */
  .stops h2 {
    /* let global h2 rules apply */
  }
  .stops-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    counter-reset: stop;
  }
  .stop-item {
    display: flex;
    gap: 1rem;
    background: var(--color-card);
    border-left: 2px solid var(--color-accent);
    padding: 1rem 1.2rem;
    transition: border-left-width 0.15s ease, background 0.15s ease;
  }
  .stop-item:hover {
    border-left-width: 3px;
    background: #fbf7eb;
  }
  .stop-num {
    flex: 0 0 auto;
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.1rem;
    color: var(--color-accent-gold);
    letter-spacing: 0.05em;
    line-height: 1.6;
    min-width: 1.6em;
  }
  .stop-thumb {
    flex: 0 0 auto;
    width: 60px;
    aspect-ratio: 3 / 4;
    padding: 3px;
    background: #fff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
    overflow: hidden;
    line-height: 0;
  }
  .stop-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .stop-thumb-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-bg-alt);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 0.6rem;
    color: var(--color-text-faint);
    letter-spacing: 0.1em;
    line-height: 1.5;
  }
  @media (max-width: 480px) {
    .stop-thumb {
      width: 48px;
    }
  }
  .stop-body {
    flex: 1;
    min-width: 0;
  }
  .stop-name {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.1rem;
    color: var(--color-ink);
    letter-spacing: 0.05em;
    margin: 0 0 0.3rem;
    padding: 0;
    border: 0;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .stop-name a {
    color: inherit;
    text-decoration: none;
  }
  .stop-name a:hover { color: var(--color-accent-gold); }
  .stop-kana {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: var(--color-text-faint);
    font-weight: normal;
    letter-spacing: 0.05em;
  }
  .stop-life {
    margin: 0 0 0.4rem;
    color: var(--color-text-muted);
    font-size: 0.78rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    letter-spacing: 0.05em;
  }
  .era-badge,
  .category-badge,
  .section-badge {
    background: var(--color-bg-alt);
    color: var(--color-text-sub);
    padding: 0.1rem 0.5rem;
    font-size: 0.68rem;
    letter-spacing: 0.05em;
  }
  .stop-note {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.75;
    color: var(--color-text-sub);
  }
</style>
