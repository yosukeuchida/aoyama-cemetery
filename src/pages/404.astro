---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'ページが見つかりません — 青山霊園 偉人録';
const description = 'お探しのページは見つかりませんでした。青山霊園 偉人録のトップから偉人一覧をご覧ください。';
---

<BaseLayout title={title} description={description}>
  <section class="not-found">
    <h1>404 — ページが見つかりません</h1>
    <p>
      お探しのページは見つかりませんでした。<br />
      URL が間違っているか、ページが移動・削除された可能性があります。
    </p>
    <ul class="not-found-actions">
      <li><a href="/">→ 偉人一覧のトップへ</a></li>
      <li><a href="/about/">→ 青山霊園について</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 3rem 1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .not-found h1 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .not-found p {
    color: #555;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .not-found-actions {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .not-found-actions a {
    display: inline-block;
    padding: 0.5rem 1rem;
    color: #5a4a2a;
    text-decoration: none;
    border-bottom: 1px dotted #a89c7d;
  }

  .not-found-actions a:hover {
    border-bottom-style: solid;
  }
</style>
