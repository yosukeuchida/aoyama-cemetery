---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const people = await getCollection('people');

const TIMELINE_START = 1795;
const TIMELINE_END = 2010;
const SPAN = TIMELINE_END - TIMELINE_START;

const CATEGORY_COLOR: Record<string, string> = {
  政治家: '#8a5a2a',
  軍人: '#6b3a2a',
  学者: '#4a5a6b',
  文化人: '#3a5a3a',
  実業家: '#8a6a2a',
  その他: '#777',
};

const CATEGORY_ORDER = ['政治家', '軍人', '実業家', '学者', '文化人', 'その他'] as const;
const ERA_ORDER = ['江戸', '明治', '大正', '昭和'] as const;

type Row = {
  id: string;
  name: string;
  nameKana: string;
  birthYear: number;
  deathYear: number;
  category: string;
  era: readonly string[];
  startPercent: number;
  widthPercent: number;
  color: string;
};

const rows: Row[] = people
  .map((p) => {
    const birthYear = parseInt(p.data.birthDate.slice(0, 4), 10);
    const deathYear = parseInt(p.data.deathDate.slice(0, 4), 10);
    const clampedBirth = Math.max(birthYear, TIMELINE_START);
    const clampedDeath = Math.min(deathYear, TIMELINE_END);
    const startPercent = ((clampedBirth - TIMELINE_START) / SPAN) * 100;
    const endPercent = ((clampedDeath - TIMELINE_START) / SPAN) * 100;
    return {
      id: p.id,
      name: p.data.name,
      nameKana: p.data.nameKana,
      birthYear,
      deathYear,
      category: p.data.category,
      era: p.data.era,
      startPercent,
      widthPercent: endPercent - startPercent,
      color: CATEGORY_COLOR[p.data.category] ?? '#777',
    };
  })
  .sort((a, b) => a.birthYear - b.birthYear || a.deathYear - b.deathYear);

const events = [
  { year: 1825, label: '異国船打払令' },
  { year: 1840, label: 'アヘン戦争' },
  { year: 1853, label: 'ペリー来航' },
  { year: 1868, label: '明治維新' },
  { year: 1894, label: '日清戦争' },
  { year: 1904, label: '日露戦争' },
  { year: 1923, label: '関東大震災' },
  { year: 1941, label: '太平洋戦争' },
  { year: 1945, label: '敗戦' },
  { year: 1960, label: '高度成長' },
];

const decadeLabels: { year: number; percent: number }[] = [];
for (let y = 1800; y <= 2000; y += 25) {
  decadeLabels.push({ year: y, percent: ((y - TIMELINE_START) / SPAN) * 100 });
}

const title = '年表(同時代タイムライン) - 青山霊園 偉人録';
const description = '青山霊園に眠る偉人 90 名超を生年順に並べた年表。江戸末期から現代まで、明治維新・日露戦争・関東大震災・太平洋戦争などの歴史的事件と人物の生涯を一画面で俯瞰できる同時代タイムライン。';

const siteOrigin = new URL('/', Astro.site).toString();

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップ', item: siteOrigin },
    { '@type': 'ListItem', position: 2, name: '年表', item: new URL('/timeline/', Astro.site).toString() },
  ],
};

const presentCategories = CATEGORY_ORDER.filter((cat) => rows.some((r) => r.category === cat));
const presentEras = ERA_ORDER.filter((era) => rows.some((r) => r.era.includes(era)));
---

<BaseLayout title={title} description={description} jsonLd={breadcrumbJsonLd}>
  <section class="hero">
    <span class="label-small">T I M E L I N E</span>
    <h1>年表 — 同時代タイムライン</h1>
    <hr class="hairline" />
    <p class="lead">
      青山霊園に眠る {rows.length} 名の偉人を生年順に並べた年表。<br />
      各人の生涯を 1 本の帯で表し、背景に幕末から現代までの主要な歴史的事件を縦線で重ねた。
    </p>
  </section>
  <p class="note">同じ時代に誰が生きていたか、明治維新・日露戦争・関東大震災・太平洋戦争を誰が共通体験したかを、一画面で俯瞰できる。各バーをクリックすると個別ページへ。</p>

  <div class="filters">
    <div class="filter-row" role="toolbar" aria-label="職業で絞り込み">
      <span class="filter-label">職業:</span>
      <button type="button" class="chip is-active" data-filter-type="category" data-filter-value="all" aria-pressed="true">すべて</button>
      {presentCategories.map((cat) => (
        <button
          type="button"
          class="chip"
          data-filter-type="category"
          data-filter-value={cat}
          aria-pressed="false"
          style={`--chip-color:${CATEGORY_COLOR[cat]};`}
        >
          {cat}
        </button>
      ))}
    </div>
    <div class="filter-row" role="toolbar" aria-label="時代で絞り込み">
      <span class="filter-label">時代:</span>
      <button type="button" class="chip is-active" data-filter-type="era" data-filter-value="all" aria-pressed="true">すべて</button>
      {presentEras.map((era) => (
        <button type="button" class="chip" data-filter-type="era" data-filter-value={era} aria-pressed="false">
          {era}
        </button>
      ))}
    </div>
    <p class="filter-count" aria-live="polite">全 {rows.length} 名</p>
  </div>

  <div class="timeline-scroll">
    <div class="timeline-grid" style={`--row-count: ${rows.length};`}>
      <div class="header-name">人物</div>
      <div class="header-bar">
        {decadeLabels.map((d) => (
          <span class="year-label" style={`left:${d.percent}%`}>{d.year}</span>
        ))}
        {events.map((e) => {
          const percent = ((e.year - TIMELINE_START) / SPAN) * 100;
          return (
            <span class="event-label" style={`left:${percent}%`} title={`${e.year}年: ${e.label}`}>
              <span class="event-label-name">{e.label}</span>
              <span class="event-label-year">{e.year}</span>
            </span>
          );
        })}
      </div>

      <div class="event-overlay" aria-hidden="true">
        {events.map((e) => {
          const percent = ((e.year - TIMELINE_START) / SPAN) * 100;
          return <div class="event-line" style={`left:${percent}%`}></div>;
        })}
      </div>

      {rows.map((row, idx) => (
        <>
          <a
            class="row-name"
            href={`/people/${row.id}/`}
            data-category={row.category}
            data-eras={row.era.join(',')}
            data-row-idx={idx}
            style={`grid-row: ${idx + 2};`}
            title={`${row.name} (${row.birthYear}-${row.deathYear})`}
          >
            {row.name}
          </a>
          <a
            class="row-bar"
            href={`/people/${row.id}/`}
            data-category={row.category}
            data-eras={row.era.join(',')}
            data-row-idx={idx}
            style={`grid-row: ${idx + 2};`}
            title={`${row.name} (${row.birthYear}-${row.deathYear}) / ${row.category}`}
          >
            <span
              class="bar"
              style={`left:${row.startPercent}%; width:${row.widthPercent}%; background:${row.color};`}
            >
              <span class="bar-year-start">{row.birthYear}</span>
              <span class="bar-year-end">{row.deathYear}</span>
            </span>
          </a>
        </>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }
  .hero .label-small { display: block; margin-bottom: 0.6rem; }
  .hero h1 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 2rem;
    letter-spacing: 0.12em;
    color: var(--color-ink);
    margin: 0 0 1.3rem;
    padding: 0;
    border: 0;
  }
  .hero .hairline { margin: 0 auto 1.3rem; }
  .hero .lead {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    line-height: 2.0;
    letter-spacing: 0.06em;
    color: var(--color-text-sub);
    max-width: var(--max-width-narrow);
    margin: 0 auto;
  }
  .note {
    color: var(--color-text-faint);
    font-size: 0.85rem;
    margin: 0.3rem 0 1rem;
  }
  .filters {
    margin: 1rem 0;
  }
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.4rem;
  }
  .filter-label {
    color: var(--color-text-sub);
    font-size: 0.85rem;
    margin-right: 0.2rem;
    flex: 0 0 auto;
  }
  .chip {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
    font-size: 0.8rem;
    cursor: pointer;
    font-family: inherit;
  }
  .chip:hover {
    background: var(--color-bg-alt);
  }
  .chip.is-active {
    background: var(--chip-color, var(--color-accent));
    color: var(--color-bg);
    border-color: var(--chip-color, var(--color-accent));
  }
  .filter-count {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin: 0.4rem 0 0;
  }

  .timeline-scroll {
    overflow: auto;
    max-height: 80vh;
    margin-top: 0.6rem;
    border: 1px solid var(--color-border);
    border-left: 2px solid var(--color-accent-gold);
    border-radius: 2px;
    background: var(--color-card);
  }
  .timeline-grid {
    display: grid;
    grid-template-columns: 130px 1fr;
    grid-template-rows: 56px repeat(var(--row-count, 1), 22px);
    min-width: 1100px;
  }

  /* Header cells (sticky top) */
  .header-name {
    grid-column: 1;
    grid-row: 1;
    position: sticky;
    top: 0;
    left: 0;
    z-index: 5;
    background: var(--color-bg-alt);
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 0.5rem 0.7rem;
    font-family: var(--font-serif);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    color: var(--color-ink);
    font-weight: 500;
    display: flex;
    align-items: center;
  }
  .header-bar {
    grid-column: 2;
    grid-row: 1;
    position: sticky;
    top: 0;
    z-index: 4;
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }
  .year-label {
    position: absolute;
    top: 6px;
    transform: translateX(-50%);
    font-size: 0.7rem;
    color: var(--color-text-faint);
    font-variant-numeric: tabular-nums;
    pointer-events: none;
  }
  .event-label {
    position: absolute;
    bottom: 4px;
    transform: translateX(-50%);
    font-size: 0.65rem;
    color: var(--color-accent-gold);
    text-align: center;
    line-height: 1.1;
    white-space: nowrap;
    font-weight: 600;
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: auto;
  }
  .event-label-year {
    color: var(--color-text-faint);
    font-weight: 500;
    font-size: 0.6rem;
  }

  /* Event overlay (spans all body rows, behind bars) */
  .event-overlay {
    grid-column: 2;
    grid-row: 2 / -1;
    position: relative;
    pointer-events: none;
    z-index: 1;
  }
  .event-line {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1px;
    background: rgba(138, 122, 74, 0.3);
  }

  /* Person rows */
  .row-name {
    grid-column: 1;
    position: sticky;
    left: 0;
    z-index: 3;
    background: var(--color-card);
    border-right: 1px solid var(--color-border-faint);
    border-bottom: 1px solid var(--color-border-faint);
    padding: 0 0.7rem;
    font-size: 0.78rem;
    color: var(--color-text);
    text-decoration: none;
    display: flex;
    align-items: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: background 120ms ease;
  }
  .row-name:hover {
    background: var(--color-bg-alt);
    color: var(--color-accent);
  }
  .row-bar {
    grid-column: 2;
    position: relative;
    border-bottom: 1px solid var(--color-border-faint);
    text-decoration: none;
    color: inherit;
    transition: background 120ms ease;
  }
  .row-bar:hover {
    background: var(--color-bg-alt);
  }
  .row-bar:hover .bar,
  .row-name:hover + .row-bar .bar,
  .row-bar:has(+ .row-name:hover) .bar {
    filter: brightness(1.1);
  }
  .row-name.is-hidden,
  .row-bar.is-hidden {
    display: none;
  }

  .bar {
    position: absolute;
    top: 4px;
    bottom: 4px;
    border-radius: 2px;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    overflow: hidden;
    min-width: 4px;
    container-type: inline-size;
  }
  .bar-year-start,
  .bar-year-end {
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.6rem;
    padding: 0 4px;
    font-variant-numeric: tabular-nums;
    flex: 0 0 auto;
  }
  .bar-year-end {
    text-align: right;
  }
  @container (max-width: 50px) {
    .bar-year-start,
    .bar-year-end {
      display: none;
    }
  }

  @media (max-width: 720px) {
    .timeline-grid {
      min-width: 900px;
      grid-template-columns: 96px 1fr;
    }
    .header-name,
    .row-name {
      padding: 0 0.4rem;
      font-size: 0.7rem;
    }
  }
</style>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
  const nameRows = document.querySelectorAll<HTMLElement>('.row-name');
  const barRows = document.querySelectorAll<HTMLElement>('.row-bar');
  const countEl = document.querySelector<HTMLElement>('.filter-count');
  const totalCount = nameRows.length;

  let currentCategory = 'all';
  let currentEra = 'all';

  function applyFilter() {
    chips.forEach((c) => {
      const type = c.dataset.filterType;
      const val = c.dataset.filterValue;
      const active =
        (type === 'category' && val === currentCategory) ||
        (type === 'era' && val === currentEra);
      c.classList.toggle('is-active', active);
      c.setAttribute('aria-pressed', active ? 'true' : 'false');
    });

    let visible = 0;
    nameRows.forEach((row, i) => {
      const barRow = barRows[i];
      const matchCat = currentCategory === 'all' || row.dataset.category === currentCategory;
      const matchEra =
        currentEra === 'all' || (row.dataset.eras ?? '').split(',').includes(currentEra);
      const match = matchCat && matchEra;
      row.classList.toggle('is-hidden', !match);
      barRow?.classList.toggle('is-hidden', !match);
      if (match) visible += 1;
    });

    if (countEl) {
      const filtered = currentCategory !== 'all' || currentEra !== 'all';
      countEl.textContent = filtered
        ? `${visible} 名を表示中 (全 ${totalCount} 名)`
        : `全 ${totalCount} 名`;
    }
  }

  chips.forEach((c) => {
    c.addEventListener('click', () => {
      const type = c.dataset.filterType;
      const val = c.dataset.filterValue ?? 'all';
      if (type === 'category') currentCategory = val;
      if (type === 'era') currentEra = val;
      applyFilter();
    });
  });

  applyFilter();
</script>
