---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildGraphData } from '../utils/build-graph-data';

const graph = await buildGraphData();
const title = '関係図 - 青山霊園 偉人録';
const description = '青山霊園に眠る 90 名の偉人の関係性を、師弟・家族・同郷・共通事件の 4 種類のエッジで可視化した関係図エクスプローラー。';

// node element 化(category 色分け・接続数 size)
const connCount = new Map<string, number>();
for (const e of graph.edges) {
  connCount.set(e.source, (connCount.get(e.source) ?? 0) + 1);
  connCount.set(e.target, (connCount.get(e.target) ?? 0) + 1);
}

const cyElements = [
  ...graph.nodes.map((n) => ({
    data: {
      id: n.id,
      label: n.name,
      category: n.category,
      era: n.era.join(','),
      region: n.region,
      jobTitle: n.jobTitle ?? '',
      shortDescription: n.shortDescription,
      degree: connCount.get(n.id) ?? 0,
    },
  })),
  ...graph.edges.map((e) => ({
    data: {
      id: e.id,
      source: e.source,
      target: e.target,
      type: e.type,
      label: e.label ?? '',
    },
  })),
];

const edgeTypeCounts: Record<string, number> = {};
for (const e of graph.edges) {
  edgeTypeCounts[e.type] = (edgeTypeCounts[e.type] ?? 0) + 1;
}
---

<BaseLayout title={title} description={description}>
  <article class="network-page">
    <header class="network-header">
      <h1>関係図</h1>
      <p class="lead">
        青山霊園に眠る {graph.nodes.length} 名の偉人を、4 種類のエッジで結んだ関係図。
        ノードをクリックで個別ページへ。マウスドラッグで移動・ホイールでズーム。
      </p>
    </header>

    <div class="network-layout">
      <aside class="network-side">
        <section class="filter-block">
          <h2>エッジの種類</h2>
          <ul class="filter-list">
            <li><label><input type="checkbox" data-edge-type="family" checked /> 家族 / 血縁 <span class="cnt">({edgeTypeCounts['family'] ?? 0})</span></label></li>
            <li><label><input type="checkbox" data-edge-type="mentorship" checked /> 師弟 / 育成 <span class="cnt">({edgeTypeCounts['mentorship'] ?? 0})</span></label></li>
            <li><label><input type="checkbox" data-edge-type="opposition" checked /> 対立 <span class="cnt">({edgeTypeCounts['opposition'] ?? 0})</span></label></li>
            <li><label><input type="checkbox" data-edge-type="alliance" checked /> 盟友 / 同志 <span class="cnt">({edgeTypeCounts['alliance'] ?? 0})</span></label></li>
            <li><label><input type="checkbox" data-edge-type="same-origin" /> 同藩 / 同郷 <span class="cnt">({edgeTypeCounts['same-origin'] ?? 0})</span></label></li>
            <li><label><input type="checkbox" data-edge-type="shared-event" /> 共通事件 <span class="cnt">({edgeTypeCounts['shared-event'] ?? 0})</span></label></li>
          </ul>
        </section>

        <section class="filter-block">
          <h2>カテゴリ</h2>
          <ul class="filter-list">
            <li><label><input type="checkbox" data-category="政治家" checked /> <span class="dot dot-政治家"></span> 政治家</label></li>
            <li><label><input type="checkbox" data-category="軍人" checked /> <span class="dot dot-軍人"></span> 軍人</label></li>
            <li><label><input type="checkbox" data-category="学者" checked /> <span class="dot dot-学者"></span> 学者</label></li>
            <li><label><input type="checkbox" data-category="文化人" checked /> <span class="dot dot-文化人"></span> 文化人</label></li>
            <li><label><input type="checkbox" data-category="実業家" checked /> <span class="dot dot-実業家"></span> 実業家</label></li>
            <li><label><input type="checkbox" data-category="その他" checked /> <span class="dot dot-その他"></span> その他</label></li>
          </ul>
        </section>

        <section class="filter-block">
          <h2>時代</h2>
          <ul class="filter-list">
            <li><label><input type="checkbox" data-era="江戸" checked /> 江戸</label></li>
            <li><label><input type="checkbox" data-era="明治" checked /> 明治</label></li>
            <li><label><input type="checkbox" data-era="大正" checked /> 大正</label></li>
            <li><label><input type="checkbox" data-era="昭和" checked /> 昭和</label></li>
          </ul>
        </section>

        <section class="filter-block">
          <h2>操作</h2>
          <button id="reset-layout">レイアウトをリセット</button>
          <button id="fit-view">全体を表示</button>
        </section>

        <section class="filter-block legend-block">
          <h2>使い方</h2>
          <ul class="tips">
            <li>ノードの大きさ = 接続数(中心人物ほど大きい)</li>
            <li>ノードをクリック → 個別ページへ</li>
            <li>ホイールでズーム、ドラッグで移動</li>
            <li>初期表示は「同郷・共通事件」を非表示(視認性のため)</li>
          </ul>
        </section>
      </aside>

      <div class="network-canvas-wrapper">
        <div id="network-info" class="network-info">
          <span id="info-hover">ホバーで人物情報を表示</span>
        </div>
        <div id="cy" class="cy-canvas"></div>
      </div>
    </div>
  </article>

  <script id="graph-elements" type="application/json" set:html={JSON.stringify(cyElements)}></script>

  <script>
    import cytoscape from 'cytoscape';

    const cyElements = JSON.parse(document.getElementById('graph-elements').textContent);

    const categoryColors = {
      政治家: '#4a6fa5',
      軍人: '#a23b56',
      学者: '#3a7a3a',
      文化人: '#7b4b94',
      実業家: '#c2762a',
      その他: '#777',
    };

    const edgeStyles = {
      family: { color: '#b8860b', width: 2.5, style: 'solid', opacity: 0.85 },
      mentorship: { color: '#2e8b57', width: 2.2, style: 'solid', opacity: 0.85 },
      opposition: { color: '#cc3344', width: 2.2, style: 'solid', opacity: 0.85 },
      alliance: { color: '#5a4a2a', width: 1.6, style: 'solid', opacity: 0.65 },
      'same-origin': { color: '#aaaa66', width: 1.2, style: 'dashed', opacity: 0.35 },
      'shared-event': { color: '#888', width: 1.0, style: 'dotted', opacity: 0.3 },
    };

    const cy = cytoscape({
      container: document.getElementById('cy'),
      elements: cyElements,
      wheelSensitivity: 0.2,
      style: [
        {
          selector: 'node',
          style: {
            'background-color': (n) => categoryColors[n.data('category')] ?? '#777',
            'label': 'data(label)',
            'font-size': '11px',
            'color': '#222',
            'text-outline-width': 2,
            'text-outline-color': '#faf8f3',
            'text-valign': 'bottom',
            'text-margin-y': 3,
            'width': (n) => Math.max(14, Math.min(40, 12 + (n.data('degree') ?? 0) * 0.7)),
            'height': (n) => Math.max(14, Math.min(40, 12 + (n.data('degree') ?? 0) * 0.7)),
            'border-width': 1,
            'border-color': '#fff',
          },
        },
        {
          selector: 'node:selected',
          style: {
            'border-width': 3,
            'border-color': '#222',
          },
        },
        ...Object.entries(edgeStyles).map(([type, s]) => ({
          selector: `edge[type = "${type}"]`,
          style: {
            'line-color': s.color,
            'width': s.width,
            'line-style': s.style,
            'opacity': s.opacity,
            'curve-style': 'bezier',
          },
        })),
        {
          selector: 'edge.hidden, node.hidden',
          style: { display: 'none' },
        },
      ],
      layout: {
        name: 'cose',
        animate: false,
        idealEdgeLength: 110,
        nodeRepulsion: 8000,
        edgeElasticity: 100,
        gravity: 0.4,
        numIter: 1500,
        randomize: true,
      },
    });

    // 初期: 同郷・共通事件は非表示(視認性のため)
    cy.elements('edge[type = "same-origin"], edge[type = "shared-event"]').addClass('hidden');

    // フィルタロジック
    function applyFilters() {
      const enabledEdgeTypes = new Set(
        Array.from(document.querySelectorAll('input[data-edge-type]:checked')).map((el) => el.dataset.edgeType)
      );
      const enabledCategories = new Set(
        Array.from(document.querySelectorAll('input[data-category]:checked')).map((el) => el.dataset.category)
      );
      const enabledEras = new Set(
        Array.from(document.querySelectorAll('input[data-era]:checked')).map((el) => el.dataset.era)
      );

      cy.batch(() => {
        cy.nodes().forEach((n) => {
          const catOk = enabledCategories.has(n.data('category'));
          const eras = (n.data('era') ?? '').split(',');
          const eraOk = eras.some((e) => enabledEras.has(e));
          if (catOk && eraOk) n.removeClass('hidden');
          else n.addClass('hidden');
        });
        cy.edges().forEach((e) => {
          const typeOk = enabledEdgeTypes.has(e.data('type'));
          const srcVisible = !e.source().hasClass('hidden');
          const tgtVisible = !e.target().hasClass('hidden');
          if (typeOk && srcVisible && tgtVisible) e.removeClass('hidden');
          else e.addClass('hidden');
        });
      });
    }

    document.querySelectorAll('input[type="checkbox"]').forEach((el) => {
      el.addEventListener('change', applyFilters);
    });
    document.getElementById('reset-layout').addEventListener('click', () => {
      cy.layout({ name: 'cose', animate: false, idealEdgeLength: 110, nodeRepulsion: 8000, gravity: 0.4, numIter: 1500, randomize: true }).run();
    });
    document.getElementById('fit-view').addEventListener('click', () => cy.fit(undefined, 30));

    // クリックで個別ページへ
    cy.on('tap', 'node', (evt) => {
      const id = evt.target.id();
      window.location.href = `/people/${id}/`;
    });

    // ホバーで情報表示
    const info = document.getElementById('info-hover');
    cy.on('mouseover', 'node', (evt) => {
      const d = evt.target.data();
      info.innerHTML = `<strong>${d.label}</strong>${d.jobTitle ? ` <span class="badge">${d.jobTitle}</span>` : ''}<br><span class="desc">${d.shortDescription}</span>`;
    });
    cy.on('mouseout', 'node', () => {
      info.innerHTML = 'ホバーで人物情報を表示';
    });
  </script>

  <style>
    .network-page {
      max-width: none;
      width: 100%;
      padding: 0;
    }
    .network-header {
      padding: 1.5rem 1.5rem 0.8rem;
      max-width: 1400px;
      margin: 0 auto;
    }
    .network-header h1 {
      margin: 0 0 0.4rem;
      font-size: 1.6rem;
    }
    .network-header .lead {
      margin: 0;
      font-size: 0.9rem;
      color: #555;
    }
    .network-layout {
      display: grid;
      grid-template-columns: 240px 1fr;
      gap: 1rem;
      padding: 1rem 1.5rem 2rem;
      max-width: 1400px;
      margin: 0 auto;
    }
    .network-side {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .filter-block {
      background: #faf8f3;
      border: 1px solid #d6d3c7;
      border-radius: 8px;
      padding: 0.7rem 0.9rem;
    }
    .filter-block h2 {
      margin: 0 0 0.5rem;
      font-size: 0.82rem;
      color: #5a4a2a;
      letter-spacing: 0.04em;
      border-bottom: 1px solid #d6d3c7;
      padding-bottom: 0.3rem;
    }
    .filter-list {
      list-style: none;
      padding: 0;
      margin: 0;
      font-size: 0.85rem;
    }
    .filter-list li {
      padding: 0.15rem 0;
    }
    .filter-list label {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      cursor: pointer;
    }
    .filter-list .cnt {
      color: #888;
      font-size: 0.75rem;
      margin-left: auto;
    }
    .dot {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      border: 1px solid #fff;
      box-shadow: 0 0 0 1px #aaa;
    }
    .dot-政治家 { background: #4a6fa5; }
    .dot-軍人 { background: #a23b56; }
    .dot-学者 { background: #3a7a3a; }
    .dot-文化人 { background: #7b4b94; }
    .dot-実業家 { background: #c2762a; }
    .dot-その他 { background: #777; }
    .filter-block button {
      display: block;
      width: 100%;
      padding: 0.4rem 0.6rem;
      margin-bottom: 0.4rem;
      background: #f0ede4;
      border: 1px solid #d6d3c7;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.83rem;
      color: #5a4a2a;
    }
    .filter-block button:hover {
      background: #e5e0d0;
    }
    .tips {
      list-style: disc;
      padding-left: 1.1rem;
      margin: 0;
      font-size: 0.78rem;
      color: #666;
      line-height: 1.55;
    }
    .network-canvas-wrapper {
      position: relative;
      border: 1px solid #d6d3c7;
      border-radius: 8px;
      background: #fdfcf7;
      overflow: hidden;
    }
    .cy-canvas {
      width: 100%;
      height: 720px;
    }
    .network-info {
      position: absolute;
      top: 0.6rem;
      left: 0.6rem;
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid #d6d3c7;
      border-radius: 5px;
      padding: 0.5rem 0.7rem;
      font-size: 0.82rem;
      color: #333;
      max-width: 420px;
      z-index: 10;
      pointer-events: none;
    }
    .network-info .badge {
      display: inline-block;
      background: #5a4a2a;
      color: #fff;
      font-size: 0.7rem;
      padding: 0.05rem 0.4rem;
      border-radius: 3px;
      margin-left: 0.3rem;
    }
    .network-info .desc {
      color: #666;
      font-size: 0.78rem;
    }

    @media (max-width: 900px) {
      .network-layout {
        grid-template-columns: 1fr;
      }
      .cy-canvas {
        height: 500px;
      }
    }
  </style>
</BaseLayout>
