---
interface Props {
  stops: Array<{
    name: string;
    lat: number;
    lng: number;
    slug: string;
  }>;
  walkOrder?: number[];
  height?: string;
}

const { stops, walkOrder, height = '420px' } = Astro.props;
const mapId = `route-map-${Math.random().toString(36).substring(2, 9)}`;
---

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<section class="route-map-section">
  <h2>散歩経路マップ</h2>
  <div id={mapId} class="route-map" style={`height: ${height};`}></div>
  <p class="map-legend">
    <small>
      マーカー番号は <strong>人物紹介の順番</strong>(時系列・物語順)です。経路ラインは <strong>効率よく歩ける順番</strong>で結んでいます。番号順と歩く順が異なるルートでは、線を辿る方が散策しやすくなります。
    </small>
  </p>
  <p class="map-attribution">
    <small>
      地図データ: &copy; <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener">OpenStreetMap</a> contributors
    </small>
  </p>
</section>

<script
  is:inline
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""></script>

<script define:vars={{ mapId, stops, walkOrder }} is:inline>
  function initRouteMap() {
    if (typeof L === 'undefined') {
      setTimeout(initRouteMap, 100);
      return;
    }

    const lats = stops.map((s) => s.lat);
    const lngs = stops.map((s) => s.lng);
    const bounds = [
      [Math.min(...lats), Math.min(...lngs)],
      [Math.max(...lats), Math.max(...lngs)],
    ];

    const map = L.map(mapId).fitBounds(bounds, { padding: [40, 40] });

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 19,
    }).addTo(map);

    // 経路ライン: walkOrder(1-indexed)指定があればその順、なければ stops 順で結ぶ
    let orderIdx;
    if (walkOrder && walkOrder.length === stops.length) {
      orderIdx = walkOrder.map((n) => n - 1);
    } else {
      orderIdx = stops.map((_, i) => i);
    }
    const walkOrderCoords = orderIdx.map((i) => [stops[i].lat, stops[i].lng]);

    L.polyline(walkOrderCoords, {
      color: '#5b8cb8',
      weight: 4,
      opacity: 0.85,
      dashArray: '6, 6',
    }).addTo(map);

    // 各 stop に番号付きマーカー
    stops.forEach((stop, i) => {
      const icon = L.divIcon({
        className: 'route-stop-marker',
        html: `<div class="route-stop-pin">${i + 1}</div>`,
        iconSize: [28, 28],
        iconAnchor: [14, 14],
        popupAnchor: [0, -14],
      });

      L.marker([stop.lat, stop.lng], { icon })
        .addTo(map)
        .bindPopup(
          `<strong>${i + 1}. <a href="/people/${stop.slug}/" style="color:#3a5448;">${stop.name}</a></strong>`
        );
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRouteMap);
  } else {
    initRouteMap();
  }
</script>

<style>
  .route-map-section {
    margin: 2rem 0;
  }
  .route-map {
    border: 1px solid var(--color-border);
    overflow: hidden;
  }
  .map-legend {
    margin: 0.6rem 0 0;
    color: var(--color-text-sub);
    line-height: 1.7;
    font-size: 0.85rem;
  }
  .map-attribution {
    margin: 0.3rem 0 0;
    color: var(--color-text-faint);
    text-align: right;
    font-size: 0.78rem;
  }
  .map-attribution a {
    color: var(--color-text-faint);
  }
</style>

<style is:global>
  .route-stop-pin {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-ink);
    color: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-family: var(--font-serif);
    font-size: 0.9rem;
    border: 2px solid var(--color-bg);
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.35);
  }
  .route-stop-marker {
    background: transparent !important;
    border: none !important;
  }
  .leaflet-popup-content a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent);
  }
</style>