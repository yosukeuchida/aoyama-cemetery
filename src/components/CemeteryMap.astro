---
import { getCollection } from 'astro:content';
import 'leaflet/dist/leaflet.css';

interface Props {
  mode: 'overview' | 'focus';
  focusSlug?: string;
}

const { mode, focusSlug } = Astro.props;

const people = await getCollection('people');
const peopleWithCoords = people
  .filter((p) => p.data.coords)
  .map((p) => ({
    slug: p.id,
    name: p.data.name,
    shortDescription: p.data.shortDescription,
    coords: p.data.coords!,
  }));

const dataPeople =
  mode === 'focus' && focusSlug
    ? peopleWithCoords.filter((p) => p.slug === focusSlug)
    : peopleWithCoords;

const shouldRender =
  (mode === 'overview' && peopleWithCoords.length > 0) ||
  (mode === 'focus' && dataPeople.length > 0);
---

{
  shouldRender && (
    <div
      class:list={['cemetery-map', `cemetery-map--${mode}`]}
      data-cemetery-map
      data-mode={mode}
      data-people={JSON.stringify(dataPeople)}
    />
  )
}

<script>
  import '../scripts/cemetery-map';
</script>

<style>
  .cemetery-map {
    width: 100%;
    border-radius: 8px;
    margin: 2rem 0;
    background: #eef2f6;
  }
  .cemetery-map--overview {
    height: 400px;
  }
  .cemetery-map--focus {
    height: 300px;
  }
</style>
