---
import type { ResolvedRelatedPerson } from '../utils/related-people';

interface Props {
  items: ResolvedRelatedPerson[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <section class="related-people">
    <h2>主要な関係人物</h2>
    <ul class="related-people-list">
      {items.map(({ person, relation }) => (
        <li class="related-person-card">
          <a href={`/people/${person.id}/`}>
            <span class="related-person-name">{person.data.name}</span>
            {person.data.jobTitle && (
              <span class="related-person-job">{person.data.jobTitle}</span>
            )}
            <span class="related-person-relation">{relation}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .related-people {
    margin-top: 2.5rem;
  }
  .related-people-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.75rem;
  }
  .related-person-card a {
    display: block;
    padding: 0.75rem 1rem;
    border: 1px solid #d6d3c7;
    border-radius: 8px;
    background: #faf8f3;
    color: inherit;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .related-person-card a:hover {
    background: #f0ede4;
    border-color: #a89c7d;
  }
  .related-person-name {
    display: block;
    font-weight: 600;
    font-size: 1.05rem;
    color: #5a4a2a;
  }
  .related-person-job {
    display: block;
    font-size: 0.78rem;
    color: #8a7a55;
    margin-top: 0.15rem;
  }
  .related-person-relation {
    display: block;
    font-size: 0.88rem;
    color: #444;
    margin-top: 0.4rem;
    line-height: 1.5;
  }
</style>
