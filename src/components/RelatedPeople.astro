---
import { Image } from 'astro:assets';
import type { ResolvedRelatedPerson } from '../utils/related-people';

interface Props {
  items: ResolvedRelatedPerson[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <section class="related-people">
    <h2>主要な関係人物</h2>
    <ul class="related-people-list">
      {items.map(({ person, relation }) => (
        <li class="related-person-card">
          <a href={`/people/${person.id}/`}>
            <div class="related-person-thumb">
              {person.data.portrait ? (
                <Image
                  src={person.data.portrait}
                  alt={`${person.data.name}の肖像`}
                  width={120}
                  quality={80}
                />
              ) : (
                <div class="related-person-thumb-placeholder">
                  <span>肖像</span>
                  <span>未公開</span>
                </div>
              )}
            </div>
            <div class="related-person-info">
              <span class="related-person-name">{person.data.name}</span>
              {person.data.jobTitle && (
                <span class="related-person-job">{person.data.jobTitle}</span>
              )}
              <span class="related-person-relation">{relation}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .related-people {
    margin-top: 2.5rem;
  }
  .related-people-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 0.75rem;
  }
  .related-person-card a {
    display: flex;
    gap: 0.8rem;
    padding: 0.8rem 1rem;
    background: var(--color-card);
    border-left: 2px solid var(--color-accent);
    color: inherit;
    text-decoration: none;
    transition: border-left-width 0.15s ease, background 0.15s ease;
  }
  .related-person-card a:hover {
    border-left-width: 3px;
    background: #fbf7eb;
  }
  .related-person-thumb {
    flex: 0 0 auto;
    width: 60px;
    aspect-ratio: 3 / 4;
    padding: 3px;
    background: #fff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
    overflow: hidden;
    line-height: 0;
  }
  .related-person-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .related-person-thumb-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-bg-alt);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 0.6rem;
    color: var(--color-text-faint);
    letter-spacing: 0.1em;
    line-height: 1.5;
  }
  .related-person-info {
    flex: 1;
    min-width: 0;
  }
  .related-person-name {
    display: block;
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.05rem;
    color: var(--color-ink);
    letter-spacing: 0.05em;
  }
  .related-person-job {
    display: block;
    font-size: 0.72rem;
    color: var(--color-text-faint);
    letter-spacing: 0.08em;
    margin-top: 0.2rem;
  }
  .related-person-relation {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-sub);
    margin-top: 0.4rem;
    line-height: 1.55;
  }
</style>
