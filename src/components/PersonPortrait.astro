---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  portrait: ImageMetadata;
  name: string;
  caption?: string;
  credit?: string;
}

const { portrait, name, caption, credit } = Astro.props;
---

<figure class="person-portrait">
  <Image
    src={portrait}
    alt={`${name}の肖像`}
    widths={[240, 360, 480]}
    sizes="(max-width: 480px) 240px, 360px"
    width={360}
    quality={85}
  />
  {(caption || credit) && (
    <figcaption>
      {caption && <span class="caption">{caption}</span>}
      {credit && <span class="credit">{credit}</span>}
    </figcaption>
  )}
</figure>

<style>
  .person-portrait {
    margin: 1rem 0 1.5rem;
    text-align: center;
  }
  .person-portrait img {
    max-width: 280px;
    width: 100%;
    height: auto;
    border-radius: 6px;
    border: 1px solid #d6d3c7;
    background: #faf8f3;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }
  figcaption {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: #8a7a55;
    line-height: 1.5;
  }
  .caption {
    display: block;
  }
  .credit {
    display: block;
    font-size: 0.75rem;
    color: #a89c7d;
    margin-top: 0.15rem;
  }
</style>
