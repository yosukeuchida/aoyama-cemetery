---
import type { Person } from '../utils/nearby-graves';

interface Props {
  block: string;
  nearby: Person[];
}

const { block, nearby } = Astro.props;
---

{nearby.length > 0 && (
  <section class="nearby-graves">
    <h2>同じ区画({block})の偉人</h2>
    <ul class="nearby-list">
      {nearby.map((p) => (
        <li class="nearby-card">
          <a href={`/people/${p.id}/`}>
            <span class="nearby-name">{p.data.name}</span>
            <span class="nearby-section">{p.data.graveSection}</span>
            <span class="nearby-desc">{p.data.shortDescription}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .nearby-graves {
    margin-top: 2.5rem;
  }
  .nearby-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.75rem;
  }
  .nearby-card a {
    display: block;
    padding: 0.75rem 1rem;
    border: 1px solid #d6d3c7;
    border-radius: 8px;
    background: #faf8f3;
    color: inherit;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .nearby-card a:hover {
    background: #f0ede4;
    border-color: #a89c7d;
  }
  .nearby-name {
    display: block;
    font-weight: 600;
    font-size: 1.05rem;
    color: #5a4a2a;
  }
  .nearby-section {
    display: block;
    font-size: 0.8rem;
    color: #8a7a55;
    margin-top: 0.15rem;
  }
  .nearby-desc {
    display: block;
    font-size: 0.85rem;
    color: #555;
    margin-top: 0.35rem;
    line-height: 1.4;
  }
</style>
